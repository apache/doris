<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.apache.doris</groupId>
        <artifactId>fe-connector</artifactId>
        <version>${revision}</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>fe-connector-cache</artifactId>
    <packaging>jar</packaging>
    <name>Doris FE Connector Cache Framework</name>
    <description>
        Shared external meta-cache framework (CacheSpec + MetaCacheEntry + CacheFactory + entry
        definitions/stats/registry). Lives under the parent-first `org.apache.doris.connector.*` prefix
        (ConnectorPluginManager loads it on the app classloader with a single Class identity), so both fe-core
        and the connector plugins reuse ONE cache framework instead of hand-rolling per-plugin caches.

        Caffeine is `provided`: the framework classes load parent-first (app classloader) and use fe-core's
        app-loader Caffeine at runtime, so no Caffeine is bundled into any plugin zip and no version collides
        across the classloader boundary. The framework's public API (MetaCacheEntry) is Caffeine-free;
        Caffeine types never cross to connector (child-first) code.
    </description>

    <dependencies>
        <dependency>
            <groupId>com.github.ben-manes.caffeine</groupId>
            <artifactId>caffeine</artifactId>
            <version>3.2.3</version>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <finalName>doris-fe-connector-cache</finalName>
    </build>
</project>
