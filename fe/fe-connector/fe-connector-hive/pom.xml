<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.apache.doris</groupId>
        <artifactId>fe-connector</artifactId>
        <version>${revision}</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>fe-connector-hive</artifactId>
    <packaging>jar</packaging>
    <name>Doris FE Connector - Hive</name>
    <description>
        Hive connector plugin for Doris FE.
        Provides metadata operations (list databases, list tables, get schema,
        partition info) for HMS-based catalogs via the connector SPI.
        Uses fe-connector-hms shared library for HMS client operations.
        Scan planning, event processing, and DML operations remain in fe-core temporarily.
    </description>

    <dependencies>
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-connector-spi</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- connector-api provides SPI interfaces -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-connector-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Thrift types for constructing TTableFormatFileDesc in populateRangeParams -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-thrift</artifactId>
            <version>${project.version}</version>
            <scope>provided</scope>
        </dependency>

        <!-- Object-store FileSystem SPI (ObjFileSystem / ObjStorage / FileSystemProvider) for the write
             transaction's multipart-upload commit/abort. MUST be provided (never bundled): these types come
             from the shared/parent classpath at runtime, and a second bundled copy would make the plugin's
             ObjFileSystem.class != the runtime instance.class, so the instanceof/downcast throws a CCE. -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-filesystem-spi</artifactId>
            <version>${project.version}</version>
            <scope>provided</scope>
        </dependency>

        <!-- Shared HMS client library -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-connector-hms</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Supplies the plugin-side HMS Kerberos parser (HmsMetaStoreProperties.kerberos() via
             MetaStoreProviders.bindForType("hms")) + transitively fe-kerberos, for
             HiveConnector.buildPluginAuthenticator; bundled child-first by plugin-zip.xml's runtime
             dependencySet. -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-connector-metastore-hms</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>org.apache.logging.log4j</groupId>
            <artifactId>log4j-api</artifactId>
        </dependency>

        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- TEST ONLY: HiveAcidUtilTest exercises the ACID descent against a real Hadoop LocalFileSystem;
             Hadoop's Configuration/LocalFileSystem reference commons-lang 2.x
             (org.apache.commons.lang.StringUtils), which is present only transitively in the runtime
             plugin closure, not on the unit-test classpath. Test-scope only — NOT bundled. Mirrors
             fe-connector-hms. Version from dependencyManagement. -->
        <dependency>
            <groupId>commons-lang</groupId>
            <artifactId>commons-lang</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <finalName>doris-fe-connector-hive</finalName>
        <plugins>
            <plugin>
                <artifactId>maven-assembly-plugin</artifactId>
                <configuration>
                    <appendAssemblyId>false</appendAssemblyId>
                    <descriptors>
                        <descriptor>src/main/assembly/plugin-zip.xml</descriptor>
                    </descriptors>
                </configuration>
                <executions>
                    <execution>
                        <id>make-assembly</id>
                        <phase>package</phase>
                        <goals>
                            <goal>single</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
