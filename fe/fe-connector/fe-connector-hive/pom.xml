<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.apache.doris</groupId>
        <artifactId>fe-connector</artifactId>
        <version>${revision}</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>fe-connector-hive</artifactId>
    <packaging>jar</packaging>
    <name>Doris FE Connector - Hive</name>
    <description>
        Hive connector plugin for Doris FE.
        Provides metadata operations (list databases, list tables, get schema,
        partition info) for HMS-based catalogs via the connector SPI.
        Uses fe-connector-hms shared library for HMS client operations.
        Scan planning, event processing, and DML operations remain in fe-core temporarily.
    </description>

    <dependencies>
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-connector-spi</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- fe-connector-cache: the shared external meta-cache framework (CacheSpec property validation +
             MetaCacheEntry/CacheFactory). fe-core does NOT depend on it, so under the parent-first
             org.apache.doris.connector.* prefix these classes resolve parent→miss→CHILD, i.e. they load from
             this plugin's own bundled jar and link against THIS plugin's Caffeine (below). The hive connector's
             scan-side metastore/file-listing cache (D2) is backed by MetaCacheEntry, which needs Caffeine at
             runtime — see the caffeine dependency next. -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-connector-cache</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Caffeine: the runtime library the shared meta-cache framework (fe-connector-cache's MetaCacheEntry/
             CacheFactory) links against. fe-connector-cache declares Caffeine `provided` (compiles against, never
             bundles), so each consuming plugin must carry its own Caffeine. Unlike the iceberg plugin (which gets
             2.9.3 transitively from iceberg-core), hive has no Caffeine on its classpath, so declare it here so
             it is bundled into the hive plugin zip (mirrors fe-connector-paimon). Pinned to 2.9.3 to match the
             version fe-connector-cache is compiled against (the lowest common version across consuming plugins). -->
        <dependency>
            <groupId>com.github.ben-manes.caffeine</groupId>
            <artifactId>caffeine</artifactId>
            <version>2.9.3</version>
        </dependency>

        <!-- connector-api provides SPI interfaces -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-connector-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Thrift types for constructing TTableFormatFileDesc in populateRangeParams -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-thrift</artifactId>
            <version>${project.version}</version>
            <scope>provided</scope>
        </dependency>

        <!-- Object-store FileSystem SPI (ObjFileSystem / ObjStorage / FileSystemProvider) for the write
             transaction's multipart-upload commit/abort. MUST be provided (never bundled): these types come
             from the shared/parent classpath at runtime, and a second bundled copy would make the plugin's
             ObjFileSystem.class != the runtime instance.class, so the instanceof/downcast throws a CCE. -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-filesystem-spi</artifactId>
            <version>${project.version}</version>
            <scope>provided</scope>
        </dependency>

        <!-- Shared HMS client library -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-connector-hms</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Supplies the plugin-side HMS Kerberos parser (HmsMetaStoreProperties.kerberos() via
             MetaStoreProviders.bindForType("hms")) + transitively fe-kerberos, for
             HiveConnector.buildPluginAuthenticator; bundled child-first by plugin-zip.xml's runtime
             dependencySet. -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-connector-metastore-hms</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>org.apache.logging.log4j</groupId>
            <artifactId>log4j-api</artifactId>
        </dependency>

        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- TEST ONLY: real Doris LocalFileSystem (org.apache.doris.filesystem.local.LocalFileSystem, "for unit
             testing only") backing HiveAcidUtilTest's ACID directory descent over a temp tree — the Doris
             equivalent of the old Hadoop LocalFileSystem, now that HiveAcidUtil lists via the injected Doris
             FileSystem. Test-scope only — NOT bundled. Depends only on fe-filesystem-spi (already provided). -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-filesystem-local</artifactId>
            <version>${project.version}</version>
            <scope>test</scope>
        </dependency>

        <!-- TEST ONLY: HiveAcidUtilTest builds its write-id snapshot with the hive-common Valid* transaction
             classes (ValidReaderWriteIdList.writeToString()), which reference commons-lang 2.x
             (org.apache.commons.lang.StringUtils); it is present only transitively in the runtime plugin
             closure, not on the unit-test classpath. Test-scope only — NOT bundled. Version from
             dependencyManagement. -->
        <dependency>
            <groupId>commons-lang</groupId>
            <artifactId>commons-lang</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <finalName>doris-fe-connector-hive</finalName>
        <plugins>
            <plugin>
                <artifactId>maven-assembly-plugin</artifactId>
                <configuration>
                    <appendAssemblyId>false</appendAssemblyId>
                    <descriptors>
                        <descriptor>src/main/assembly/plugin-zip.xml</descriptor>
                    </descriptors>
                </configuration>
                <executions>
                    <execution>
                        <id>make-assembly</id>
                        <phase>package</phase>
                        <goals>
                            <goal>single</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
