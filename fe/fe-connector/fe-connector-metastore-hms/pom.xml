<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.apache.doris</groupId>
        <artifactId>fe-connector</artifactId>
        <version>${revision}</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>fe-connector-metastore-hms</artifactId>
    <packaging>jar</packaging>
    <name>Doris FE Connector Metastore HMS</name>
    <description>
        The neutral, engine-agnostic Hive Metastore (HMS) metastore backend: the concrete
        DefaultHmsMetaStoreProperties impl + its MetaStoreProvider entry (META-INF/services), discovered by
        ServiceLoader at CREATE-CATALOG time. The shared extension point, framework, and engine-neutral HMS
        conf base (AbstractHmsMetaStoreProperties) live in fe-connector-metastore-spi; this module supplies
        only the neutral flavor of validate() — the shared HMS connection check, with no warehouse
        requirement (HMS is a metastore, not a storage). Bundled child-first into the consuming connector
        plugin-zip (NOT compiled into fe-core); only that plugin classpath sees this provider, so
        bindForType("hms") resolves within-engine.
    </description>

    <dependencies>
        <!-- Extension point + framework + engine-neutral HMS/DLF conf bases
             (Abstract{Hms,Dlf}MetaStoreProperties, MetaStoreProvider(s), MetaStoreParseUtils,
             JdbcDriverSupport). Transitively pulls metastore-api + fe-kerberos + fe-extension-spi +
             fe-foundation. -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-connector-metastore-spi</artifactId>
            <version>${project.version}</version>
        </dependency>
        <!-- The neutral HmsMetaStoreProperties contract the HMS impl implements (also transitive via -spi;
             declared directly for clarity). -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-connector-metastore-api</artifactId>
            <version>${project.version}</version>
        </dependency>
        <!-- @ConnectorProperty + ConnectorPropertiesUtils (typed-holder binding in the of() factory). -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-foundation</artifactId>
            <version>${project.version}</version>
        </dependency>
        <!-- AuthType + KerberosAuthSpec value objects (the HMS conf base + its parity test use them;
             also transitive via -spi/-api). -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-kerberos</artifactId>
            <version>${project.version}</version>
        </dependency>
        <!-- StringUtils — match the legacy HMS properties' exact blank semantics. -->
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-lang3</artifactId>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <finalName>doris-fe-connector-metastore-hms</finalName>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <executions>
                    <!-- A library jar bundled into the consuming connector plugin-zip (via that module's
                         assembly dependencySet), not a standalone plugin: nothing to copy here. -->
                    <execution>
                        <id>copy-plugin-deps</id>
                        <phase>none</phase>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
