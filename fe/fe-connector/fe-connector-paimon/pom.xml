<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.apache.doris</groupId>
        <artifactId>fe-connector</artifactId>
        <version>${revision}</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>fe-connector-paimon</artifactId>
    <packaging>jar</packaging>
    <name>Doris FE Connector - Paimon</name>
    <description>
        Paimon connector plugin for Doris FE.
        Provides metadata operations (list databases, list tables, get schema)
        for Paimon catalogs via the connector SPI.
        Supports multiple catalog backends: filesystem, HMS, DLF, REST, JDBC.
        Scan planning, predicate pushdown, and DML operations remain in fe-core temporarily.
    </description>

    <dependencies>
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-connector-spi</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- connector-api provides SPI interfaces -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-connector-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Thrift types for constructing TTableFormatFileDesc in populateRangeParams -->
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>fe-thrift</artifactId>
            <version>${project.version}</version>
            <scope>provided</scope>
        </dependency>

        <!-- Paimon SDK -->
        <dependency>
            <groupId>org.apache.paimon</groupId>
            <artifactId>paimon-core</artifactId>
            <version>${paimon.version}</version>
        </dependency>

        <!-- paimon-hive-connector-3.1 supplies org.apache.paimon.hive.HiveCatalogFactory (the
             SPI impl discovered for metastore=hive) + HiveCatalogOptions, needed so the hms/dlf
             flavors can create a live HiveCatalog. Version comes from dependencyManagement
             (${paimon.version}, declared groupId+artifactId only like paimon-core). Its hive-exec
             dep is `provided` and hadoop-client is `test`, so it does NOT drag Configuration/HiveConf
             onto our compile classpath — those come from the two deps below.
             NOTE (cutover P5-B7): the Thrift metastore client (IMetaStoreClient/HiveMetaStoreClient)
             for the live metastore=hive (hms/dlf) path is therefore NOT bundled here; it is
             host-provided via the FE's hive-catalog-shade at cutover, not at connector compile time
             (see the NOTE blocks in PaimonConnector.createCatalog hms/dlf branches). -->
        <dependency>
            <groupId>org.apache.paimon</groupId>
            <artifactId>paimon-hive-connector-3.1</artifactId>
        </dependency>

        <!-- hadoop-common supplies org.apache.hadoop.conf.Configuration, reconstructed minimally
             from the raw property map in PaimonCatalogFactory.buildHadoopConfiguration (this
             replaces fe-core StorageProperties.getHadoopStorageConfig, which the connector cannot
             import). Version + exclusions mirror fe-core's dependencyManagement entry
             (${hadoop.version}). -->
        <dependency>
            <groupId>org.apache.hadoop</groupId>
            <artifactId>hadoop-common</artifactId>
        </dependency>

        <!-- hadoop-aws supplies org.apache.hadoop.fs.s3a.S3AFileSystem, the ONLY Hadoop FileSystem impl
             missing from the plugin jar (the transitively-bundled hadoop-client-api already carries
             FileSystem / hdfs DistributedFileSystem / SecurityUtil / DNSDomainNameResolver). The plugin
             runs child-first (org.apache.hadoop is not parent-first); bundling hadoop-common/client-api
             WITHOUT hadoop-aws left FileSystem in the child loader while S3AFileSystem resolved from the
             parent 'app' loader — a cross-classloader split that threw 'S3AFileSystem cannot be cast to
             FileSystem' and poisoned SecurityUtil (FIX-PAIMON-HADOOP-CLASSLOADER). Self-containing the
             FS impls here (not delegating hadoop to the parent) is the correct end-state: fe-core's
             hadoop/hive-catalog-shade is removed after full connector migration. Version + exclusions
             inherited from fe-core's dependencyManagement (${hadoop.version}). hadoop-aws:3.4.2 declares
             its AWS SDK v2 as software.amazon.awssdk:bundle, which fe/pom.xml excludes on the hadoop-aws
             dep — so the SDK is bundled here explicitly (below) child-first (RC-3), giving the plugin's S3A
             its own ExecutionAttribute static instead of colliding on fe-core's. -->
        <dependency>
            <groupId>org.apache.hadoop</groupId>
            <artifactId>hadoop-aws</artifactId>
        </dependency>

        <!-- hadoop-huaweicloud supplies org.apache.hadoop.fs.obs.OBSFileSystem for obs:// warehouses, the
             SAME self-contained reasoning as hadoop-aws above: the plugin runs child-first with hadoop-common
             (FileSystem) bundled in the child loader. Without hadoop-huaweicloud here, OBSFileSystem resolved
             from the parent 'app' loader while FileSystem resolved from the child ChildFirstClassLoader, so
             FileSystem.createFileSystem's cast threw "OBSFileSystem cannot be cast to FileSystem"
             (FIX-PAIMON-OBS-SELFCONTAINED, CI 968994 paimon_base_filesystem). Bundling it child-first
             co-locates OBSFileSystem with the plugin's own FileSystem so the cast succeeds. Version + scope
             (compile) + jackson-databind exclusion inherited from fe-core dependencyManagement
             (${huaweiobs.version}); the esdk-obs SDK rides transitively. hadoop-common stays the plugin's
             own direct (depth-1) copy via Maven mediation, so no duplicate FileSystem is introduced. -->
        <dependency>
            <groupId>com.huaweicloud</groupId>
            <artifactId>hadoop-huaweicloud</artifactId>
        </dependency>

        <!-- AWS SDK v2 for the child-bundled hadoop-aws S3AFileSystem (RC-3, completes
             FIX-PAIMON-HADOOP-CLASSLOADER). Without it the plugin bundles S3AFileSystem child-first but NO
             SDK: its S3AInternalAuditConstants.<clinit> registers an ExecutionAttribute against the single
             PARENT-loaded sdk-core static, colliding with fe-core's S3A in ExecutionAttribute.ensureUnique()
             -> ExceptionInInitializerError that permanently poisons S3A for the whole FE JVM (iceberg+paimon).
             The 's3' module's compile closure brings sdk-core (the load-bearing ExecutionAttribute) + aws-core
             + auth + regions + the spi/protocol/checksums modules; apache-client is added explicitly because
             hadoop-aws 3.4.2 wires ApacheHttpClient and it is only test-scoped in s3's closure. Versions are
             BOM-managed (awssdk ${awssdk.version}, matching fe-core). software.amazon.awssdk MUST stay
             child-first (NOT in the parent-first allowlist) — that separate child copy of the SDK is the
             whole point. (STS/assumed-role would need software.amazon.awssdk:sts added the same way.) -->
        <dependency>
            <groupId>software.amazon.awssdk</groupId>
            <artifactId>s3</artifactId>
        </dependency>
        <dependency>
            <groupId>software.amazon.awssdk</groupId>
            <artifactId>apache-client</artifactId>
        </dependency>
        <!-- s3-transfer-manager completes the RC-3 AWS-SDK closure. hadoop-aws 3.4.2 pulls
             software.amazon.s3.analyticsaccelerator:analyticsaccelerator-s3, whose ApacheHttpClient/S3 client
             build loads the SPI resource software/amazon/awssdk/services/s3/execution.interceptors. That
             resource (listing software.amazon.awssdk.transfer.s3.internal.ApplyUserAgentInterceptor) lives
             ONLY in s3-transfer-manager.jar — NOT in s3.jar. With s3-transfer-manager unbundled, the plugin's
             child-first sdk-core ClasspathInterceptorChainFactory found NO child copy of the resource, so
             ChildFirstClassLoader.getResources fell back to the PARENT s3-transfer-manager, loading its
             ApplyUserAgentInterceptor (which implements the PARENT sdk-core's ExecutionInterceptor) — a
             different Class than the child sdk-core's ExecutionInterceptor → SdkClientException "request
             handler ... does not implement the interface ... ExecutionInterceptor", which broke S3A and
             cascaded to "Could not find a file io implementation for scheme 's3'" + "Unknown database"
             (FIX-PAIMON-S3-TRANSFER-MANAGER, CI 968994). Bundling it child-first (BOM-managed
             ${awssdk.version}, matching the s3/sdk-core already bundled) puts ApplyUserAgentInterceptor +
             the execution.interceptors resource in the child loader so they resolve against the child
             sdk-core. MUST stay child-first like the rest of software.amazon.awssdk. -->
        <dependency>
            <groupId>software.amazon.awssdk</groupId>
            <artifactId>s3-transfer-manager</artifactId>
        </dependency>

        <!-- hive-common supplies org.apache.hadoop.hive.conf.HiveConf for the hms/dlf flavors
             (buildHmsHiveConf / buildDlfHiveConf). We deliberately use the plain hive-common
             (${hive.common.version}) rather than fe-core's hive-catalog-shade: the shade bundles an
             ancient, unrelocated fastutil (6.5.6) that collides on the classpath; hive-common does
             not, so the connector module stays conflict-free. -->
        <dependency>
            <groupId>org.apache.hive</groupId>
            <artifactId>hive-common</artifactId>
        </dependency>

        <!-- RC-5: bundle the 2.x Thrift metastore client (RetryingMetaStoreClient / HiveMetaStoreClient /
             HiveMetaHookLoader + metastore api) child-first so its getProxy(HiveConf,...) overloads are
             compiled against the SAME org.apache.hadoop.hive.conf.HiveConf the connector's
             RetryingMetaStoreClientFactory probes from the child-bundled hive-common-2.3.9 + hadoop-common.
             Without it those classes resolve from the parent hive-catalog-shade-3.1.1 (Configuration-based
             getProxy only) -> Class-identity mismatch -> every reflective probe throws NoSuchMethodException
             -> "Failed to create the desired metastore client". 2.3.7 is the only 2.x metastore line in the
             repo and pairs with hive-common 2.3.9 (patch-level, API-stable HiveConf); the jar is
             fastutil-CLEAN, so unlike hive-catalog-shade it does NOT reintroduce the fastutil collision.
             Bundle ONLY the client+api closure (libfb303 rides transitively); exclude server-side
             datanucleus/derby/bonecp/HikariCP/jdo/hbase/tephra, the stale hadoop-2.7.2 trio + guava, and
             libthrift (stays parent-first like the other connectors). NOTE: thrift 0.9.3-vs-host-0.16.0 wire
             skew + the DLF ProxyMetaStoreClient path are not statically provable — gated by the docker
             paimon suite (enablePaimonTest=true). -->
        <dependency>
            <groupId>org.apache.hive</groupId>
            <artifactId>hive-metastore</artifactId>
            <version>2.3.7</version>
            <exclusions>
                <exclusion><groupId>org.apache.hadoop</groupId><artifactId>hadoop-common</artifactId></exclusion>
                <exclusion><groupId>org.apache.hadoop</groupId><artifactId>hadoop-hdfs</artifactId></exclusion>
                <exclusion><groupId>org.apache.hadoop</groupId><artifactId>hadoop-mapreduce-client-core</artifactId></exclusion>
                <exclusion><groupId>org.apache.hive</groupId><artifactId>hive-common</artifactId></exclusion>
                <exclusion><groupId>org.apache.hive</groupId><artifactId>hive-serde</artifactId></exclusion>
                <exclusion><groupId>org.apache.hive</groupId><artifactId>hive-shims</artifactId></exclusion>
                <exclusion><groupId>org.apache.thrift</groupId><artifactId>libthrift</artifactId></exclusion>
                <exclusion><groupId>com.google.guava</groupId><artifactId>guava</artifactId></exclusion>
                <exclusion><groupId>com.google.protobuf</groupId><artifactId>protobuf-java</artifactId></exclusion>
                <exclusion><groupId>org.datanucleus</groupId><artifactId>datanucleus-api-jdo</artifactId></exclusion>
                <exclusion><groupId>org.datanucleus</groupId><artifactId>datanucleus-core</artifactId></exclusion>
                <exclusion><groupId>org.datanucleus</groupId><artifactId>datanucleus-rdbms</artifactId></exclusion>
                <exclusion><groupId>org.datanucleus</groupId><artifactId>javax.jdo</artifactId></exclusion>
                <exclusion><groupId>javax.jdo</groupId><artifactId>jdo-api</artifactId></exclusion>
                <exclusion><groupId>org.apache.derby</groupId><artifactId>derby</artifactId></exclusion>
                <exclusion><groupId>com.jolbox</groupId><artifactId>bonecp</artifactId></exclusion>
                <exclusion><groupId>com.zaxxer</groupId><artifactId>HikariCP</artifactId></exclusion>
                <exclusion><groupId>commons-dbcp</groupId><artifactId>commons-dbcp</artifactId></exclusion>
                <exclusion><groupId>commons-pool</groupId><artifactId>commons-pool</artifactId></exclusion>
                <exclusion><groupId>org.apache.hbase</groupId><artifactId>hbase-client</artifactId></exclusion>
                <exclusion><groupId>co.cask.tephra</groupId><artifactId>tephra-api</artifactId></exclusion>
                <exclusion><groupId>co.cask.tephra</groupId><artifactId>tephra-core</artifactId></exclusion>
                <exclusion><groupId>co.cask.tephra</groupId><artifactId>tephra-hbase-compat-1.0</artifactId></exclusion>
                <exclusion><groupId>ch.qos.logback</groupId><artifactId>logback-classic</artifactId></exclusion>
                <exclusion><groupId>ch.qos.logback</groupId><artifactId>logback-core</artifactId></exclusion>
                <exclusion><groupId>org.slf4j</groupId><artifactId>slf4j-log4j12</artifactId></exclusion>
                <exclusion><groupId>commons-logging</groupId><artifactId>commons-logging</artifactId></exclusion>
            </exclusions>
        </dependency>

        <dependency>
            <groupId>org.apache.logging.log4j</groupId>
            <artifactId>log4j-api</artifactId>
        </dependency>

        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- TEST ONLY: the offline FE->BE serde round-trip smoke
             (PaimonTableSerdeRoundTripTest) builds a REAL local-filesystem catalog and
             createTable()'s a table; paimon's table writer/validator resolves the default
             'parquet' FileFormatFactory, which ships in paimon-format. This is already on the FE
             runtime classpath in fe-core and on BE's paimon-scanner classpath, so it is not a new
             runtime dependency for the connector — only the offline smoke needs it at test time.
             Version comes from dependencyManagement (${paimon.version}, R-007). -->
        <dependency>
            <groupId>org.apache.paimon</groupId>
            <artifactId>paimon-format</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <finalName>doris-fe-connector-paimon</finalName>
        <plugins>
            <plugin>
                <artifactId>maven-assembly-plugin</artifactId>
                <configuration>
                    <appendAssemblyId>false</appendAssemblyId>
                    <descriptors>
                        <descriptor>src/main/assembly/plugin-zip.xml</descriptor>
                    </descriptors>
                </configuration>
                <executions>
                    <execution>
                        <id>make-assembly</id>
                        <phase>package</phase>
                        <goals>
                            <goal>single</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
