    define can_admin: [user] or can_admin from parent
    define can_node: [user] or can_admin or can_node from parent
    define can_grant: [user] or can_admin or can_grant from parent
    define can_select: [user] or can_admin or can_select from parent
    define can_load: [user] or can_admin or can_load from parent
    define can_alter: [user] or can_admin or can_alter from parent
    define can_create: [user] or can_admin or can_create from parent
    define can_drop: [user] or can_admin or can_drop from parent
    define can_usage: [user] or can_admin or can_usage from parent
    define can_show_view: [user] or can_admin or can_show_view from parent
