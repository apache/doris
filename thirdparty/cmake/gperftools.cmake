")

# Copy all public headers to the expected output dir
file(COPY ${GPERF_SRC}/gperftools/ DESTINATION ${GPERF_OUT_INC}/gperftools FILES_MATCHING PATTERN "*.h")

# Set variables needed by tcmalloc.h.in @ONLY substitution
set(TC_VERSION_MAJOR 2)
set(TC_VERSION_MINOR 10)
set(TC_VERSION_PATCH "")
set(ac_cv_have_struct_mallinfo 1)
set(ac_cv_have_std_align_val_t 0)

# Generate tcmalloc.h from .h.in template
configure_file(${GPERF_SRC}/gperftools/tcmalloc.h.in ${GPERF_OUT_INC}/gperftools/tcmalloc.h @ONLY)

# Generate stacktrace.h
if(EXISTS ${GPERF_SRC}/gperftools/stacktrace.h.in)
    configure_file(${GPERF_SRC}/gperftools/stacktrace.h.in ${GPERF_OUT_INC}/gperftools/stacktrace.h @ONLY)
endif()

# Core tcmalloc sources
set(GPERF_TCMALLOC_SRCS
    ${GPERF_SRC}/central_freelist.cc
    ${GPERF_SRC}/common.cc
    ${GPERF_SRC}/internal_logging.cc
    ${GPERF_SRC}/malloc_extension.cc
    ${GPERF_SRC}/malloc_hook.cc
    ${GPERF_SRC}/maybe_threads.cc
    ${GPERF_SRC}/memfs_malloc.cc
    ${GPERF_SRC}/memory_region_map.cc
    ${GPERF_SRC}/page_heap.cc
    ${GPERF_SRC}/raw_printer.cc
    ${GPERF_SRC}/sampler.cc
    ${GPERF_SRC}/span.cc
    ${GPERF_SRC}/stack_trace_table.cc
    ${GPERF_SRC}/stacktrace.cc
    ${GPERF_SRC}/static_vars.cc
    ${GPERF_SRC}/symbolize.cc
    ${GPERF_SRC}/system-alloc.cc
    ${GPERF_SRC}/tcmalloc.cc
    ${GPERF_SRC}/heap-profile-table.cc
    ${GPERF_SRC}/heap-profiler.cc
    ${GPERF_SRC}/emergency_malloc.cc
    ${GPERF_SRC}/emergency_malloc_for_stacktrace.cc
    ${GPERF_SRC}/fake_stacktrace_scope.cc
    # base/
    ${GPERF_SRC}/base/dynamic_annotations.c
    ${GPERF_SRC}/base/elf_mem_image.cc
    ${GPERF_SRC}/base/logging.cc
    ${GPERF_SRC}/base/low_level_alloc.cc
    ${GPERF_SRC}/base/spinlock.cc
    ${GPERF_SRC}/base/spinlock_internal.cc
    ${GPERF_SRC}/base/sysinfo.cc
    ${GPERF_SRC}/base/vdso_support.cc
    ${GPERF_SRC}/base/linuxthreads.cc
    ${GPERF_SRC}/base/thread_lister.c
)

# Profiler sources
set(GPERF_PROFILER_SRCS
    ${GPERF_SRC}/profiler.cc
    ${GPERF_SRC}/profile-handler.cc
    ${GPERF_SRC}/profiledata.cc
    ${GPERF_SRC}/stacktrace.cc
    ${GPERF_SRC}/maybe_threads.cc
    ${GPERF_SRC}/fake_stacktrace_scope.cc
    ${GPERF_SRC}/base/dynamic_annotations.c
    ${GPERF_SRC}/base/elf_mem_image.cc
    ${GPERF_SRC}/base/logging.cc
    ${GPERF_SRC}/base/spinlock.cc
    ${GPERF_SRC}/base/spinlock_internal.cc
    ${GPERF_SRC}/base/sysinfo.cc
    ${GPERF_SRC}/base/vdso_support.cc
)

# tcmalloc library
add_library(_tcmalloc STATIC ${GPERF_TCMALLOC_SRCS})
target_include_directories(_tcmalloc
    PRIVATE ${GPERF_CONFIG_DIR}
    PRIVATE ${GPERF_SRC}
    PUBLIC  ${GPERF_OUT_INC}       # consolidated public headers (copied + generated tcmalloc.h)
    PUBLIC  ${GPERF_ROOT}/src
)
target_compile_definitions(_tcmalloc PRIVATE HAVE_CONFIG_H _GNU_SOURCE NO_FRAME_POINTER)
target_compile_options(_tcmalloc PRIVATE -fPIC -w -fno-builtin-malloc -fno-builtin-free -fno-builtin-realloc -fno-builtin-calloc -fno-builtin-memalign -fno-builtin-posix_memalign -fno-builtin-valloc -fno-builtin-pvalloc)
target_link_libraries(_tcmalloc PRIVATE pthread)
add_library(tcmalloc ALIAS _tcmalloc)

# profiler library
add_library(_pprof STATIC ${GPERF_PROFILER_SRCS})
target_include_directories(_pprof
    PRIVATE ${GPERF_CONFIG_DIR}
    PRIVATE ${GPERF_SRC}
    PUBLIC  ${GPERF_OUT_INC}
    PUBLIC  ${GPERF_ROOT}/src
)
target_compile_definitions(_pprof PRIVATE HAVE_CONFIG_H _GNU_SOURCE)
target_compile_options(_pprof PRIVATE -fPIC -w)
target_link_libraries(_pprof PRIVATE pthread)
add_library(pprof ALIAS _pprof)
