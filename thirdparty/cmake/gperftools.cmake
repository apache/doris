#define PACKAGE \"gperftools\"
#define PACKAGE_VERSION \"2.10\"
#define VERSION \"2.10\"
#define PACKAGE_STRING \"gperftools 2.10\"
#define ENABLE_LARGE_ALLOC_REPORT 0
