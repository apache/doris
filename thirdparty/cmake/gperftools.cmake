# gperftools — pure CMake build (no autoconf)
# Build tcmalloc + profiler for Linux x86_64.
# Only the core non-test sources are compiled.

set(GPERF_SRC ${TP_SOURCE_DIR}/gperftools-2.10/src)
set(GPERF_ROOT ${TP_SOURCE_DIR}/gperftools-2.10)
set(GPERF_CONFIG_DIR ${CMAKE_CURRENT_BINARY_DIR}/gperftools_config)
set(GPERF_OUT_INC ${CMAKE_BINARY_DIR}/thirdparty/gperftools/include)
file(MAKE_DIRECTORY ${GPERF_CONFIG_DIR}/gperftools)
file(MAKE_DIRECTORY ${GPERF_OUT_INC}/gperftools)

# Generate config.h
file(WRITE ${GPERF_CONFIG_DIR}/config.h
"/* Generated by CMake — gperftools config for Linux x86_64 */
#ifndef GPERFTOOLS_CONFIG_H_
#define GPERFTOOLS_CONFIG_H_
#define STDC_HEADERS 1
#define HAVE_STDINT_H 1
