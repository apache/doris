# arrow (Apache Arrow + Parquet)
# Arrow has an extremely complex build. Use its CMake with minimal options.
set(ARROW_BUILD_STATIC ON CACHE BOOL "" FORCE)
set(ARROW_BUILD_SHARED OFF CACHE BOOL "" FORCE)
set(ARROW_BUILD_TESTS OFF CACHE BOOL "" FORCE)
set(ARROW_BUILD_BENCHMARKS OFF CACHE BOOL "" FORCE)
set(ARROW_BUILD_EXAMPLES OFF CACHE BOOL "" FORCE)
set(ARROW_BUILD_UTILITIES OFF CACHE BOOL "" FORCE)
set(ARROW_COMPUTE ON CACHE BOOL "" FORCE)
set(ARROW_DATASET ON CACHE BOOL "" FORCE)
set(ARROW_ACERO ON CACHE BOOL "" FORCE)
set(ARROW_FILESYSTEM ON CACHE BOOL "" FORCE)
set(ARROW_FLIGHT ON CACHE BOOL "" FORCE)
set(ARROW_FLIGHT_SQL ON CACHE BOOL "" FORCE)
set(ARROW_WITH_BROTLI ON CACHE BOOL "" FORCE)
set(ARROW_WITH_BZ2 ON CACHE BOOL "" FORCE)
set(ARROW_WITH_LZ4 ON CACHE BOOL "" FORCE)
set(ARROW_WITH_SNAPPY ON CACHE BOOL "" FORCE)
set(ARROW_WITH_ZLIB ON CACHE BOOL "" FORCE)
set(ARROW_WITH_ZSTD ON CACHE BOOL "" FORCE)
set(ARROW_WITH_RE2 ON CACHE BOOL "" FORCE)
set(ARROW_WITH_UTF8PROC OFF CACHE BOOL "" FORCE)
set(ARROW_PARQUET ON CACHE BOOL "" FORCE)
set(ARROW_JSON ON CACHE BOOL "" FORCE)
set(ARROW_CSV ON CACHE BOOL "" FORCE)
set(ARROW_IPC ON CACHE BOOL "" FORCE)
set(ARROW_JEMALLOC OFF CACHE BOOL "" FORCE)
set(ARROW_MIMALLOC OFF CACHE BOOL "" FORCE)
set(ARROW_DEPENDENCY_USE_SHARED OFF CACHE BOOL "" FORCE)
set(ARROW_DEPENDENCY_SOURCE SYSTEM CACHE STRING "" FORCE)
# Point to our pre-built/co-built deps
set(OPENSSL_ROOT_DIR ${TP_INSTALL_DIR} CACHE PATH "" FORCE)
set(Protobuf_ROOT ${TP_INSTALL_DIR} CACHE PATH "" FORCE)
set(gRPC_ROOT ${TP_INSTALL_DIR} CACHE PATH "" FORCE)
add_subdirectory(${TP_SOURCE_DIR}/arrow-apache-arrow-17.0.0/cpp ${CMAKE_CURRENT_BINARY_DIR}/arrow EXCLUDE_FROM_ALL)
