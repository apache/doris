# arrow (Apache Arrow + Parquet) — hand-written add_library calls (no add_subdirectory)
#
# Targets built:
#   arrow_static         — core Arrow library (array, compute, io, ipc, csv, json, filesystem, util)
#   arrow_flight_static  — Arrow Flight RPC
#   arrow_flight_sql_static — Arrow Flight SQL
#   arrow_acero_static   — Arrow Acero execution engine
#   arrow_dataset_static — Arrow Dataset
#   parquet_static       — Apache Parquet
#
# Pre-generated files used (from src/arrow-apache-arrow-17.0.0/cpp/src/generated/):
#   parquet_constants.cpp, parquet_types.cpp  (generated by thrift)
# Proto files for Flight are compiled at build time via add_custom_command.

set(_ARROW_SRC "${TP_SOURCE_DIR}/arrow-apache-arrow-17.0.0/cpp/src")
set(_ARROW_FMT "${TP_SOURCE_DIR}/arrow-apache-arrow-17.0.0/format")

# ============================================================================
# Alias setup from original arrow.cmake (needed by downstream consumers)
# ============================================================================

# Pre-configure gflags for Arrow.
get_target_property(_gflags_inc_dirs gflags_static INTERFACE_INCLUDE_DIRECTORIES)
list(GET _gflags_inc_dirs 0 _gflags_inc)
set(gflagsAlt_FOUND TRUE CACHE BOOL "" FORCE)
set(GFLAGS_FOUND TRUE CACHE BOOL "" FORCE)
set(gflags_FOUND TRUE CACHE BOOL "" FORCE)
set(GFLAGS_INCLUDE_DIR "${_gflags_inc}" CACHE PATH "" FORCE)
set(gflags_LIB gflags_static CACHE STRING "" FORCE)
set(GFLAGS_LIBRARIES gflags_static CACHE STRING "" FORCE)
if(NOT TARGET gflags::gflags)
    add_library(gflags::gflags INTERFACE IMPORTED GLOBAL)
    target_link_libraries(gflags::gflags INTERFACE gflags_static)
    target_include_directories(gflags::gflags INTERFACE "${_gflags_inc}")
endif()
if(NOT TARGET gflags::gflags_static)
    add_library(gflags::gflags_static INTERFACE IMPORTED GLOBAL)
    target_link_libraries(gflags::gflags_static INTERFACE gflags_static)
    target_include_directories(gflags::gflags_static INTERFACE "${_gflags_inc}")
endif()

# Pre-configure thrift for Arrow.
if(TARGET thrift_static)
    get_target_property(_thrift_bin thrift_static BINARY_DIR)
else()
    set(_thrift_bin "${CMAKE_CURRENT_BINARY_DIR}/thrift")
endif()
set(_thrift_include "${TP_SOURCE_DIR}/thrift-0.16.0/lib/cpp/src;${_thrift_bin};${TP_SOURCE_DIR}/boost_1_81_0")
set(ThriftAlt_FOUND TRUE CACHE BOOL "" FORCE)
set(Thrift_FOUND TRUE CACHE BOOL "" FORCE)
set(ThriftAlt_LIB "${_thrift_bin}/lib/libthrift.a" CACHE INTERNAL "")
set(ThriftAlt_INCLUDE_DIR "${_thrift_include}" CACHE INTERNAL "")
set(ThriftAlt_VERSION "0.16.0" CACHE INTERNAL "")
if(NOT TARGET thrift::thrift)
    add_library(thrift::thrift INTERFACE IMPORTED GLOBAL)
    if(TARGET thrift_static)
        target_link_libraries(thrift::thrift INTERFACE thrift_static)
    endif()
    target_include_directories(thrift::thrift INTERFACE "${_thrift_include}")
endif()

# ============================================================================
# Validate that pre-generated config headers exist; if not, provide guidance.
# (Checked early so the error is clear before configure_file fails.)
# ============================================================================
if(NOT EXISTS "${CMAKE_CURRENT_SOURCE_DIR}/cmake/generated/arrow/util/config.h")
    message(FATAL_ERROR
        "Arrow pre-generated config.h not found at:\n"
        "  ${CMAKE_CURRENT_SOURCE_DIR}/cmake/generated/arrow/util/config.h\n"
        "Copy it from a completed Arrow build:\n"
        "  be/build_Release/thirdparty/arrow/src/arrow/util/config.h\n"
        "  → thirdparty/cmake/generated/arrow/util/config.h"
    )
endif()
if(NOT EXISTS "${CMAKE_CURRENT_SOURCE_DIR}/cmake/generated/arrow/util/config_internal.h")
    message(FATAL_ERROR
        "Arrow pre-generated config_internal.h not found at:\n"
        "  ${CMAKE_CURRENT_SOURCE_DIR}/cmake/generated/arrow/util/config_internal.h\n"
        "Copy it from a completed Arrow build:\n"
        "  be/build_Release/thirdparty/arrow/src/arrow/util/config_internal.h\n"
        "  → thirdparty/cmake/generated/arrow/util/config_internal.h"
    )
endif()
if(NOT EXISTS "${CMAKE_CURRENT_SOURCE_DIR}/cmake/generated/parquet/parquet_version.h")
    message(FATAL_ERROR
        "Parquet pre-generated parquet_version.h not found at:\n"
        "  ${CMAKE_CURRENT_SOURCE_DIR}/cmake/generated/parquet/parquet_version.h\n"
        "Copy it from a completed Arrow build:\n"
        "  be/build_Release/thirdparty/arrow/src/parquet/parquet_version.h\n"
        "  → thirdparty/cmake/generated/parquet/parquet_version.h"
    )
endif()

# ============================================================================
# Config headers — copy pre-generated files into the binary dir
# ============================================================================
# These headers were generated by the upstream Arrow build (arrow/util/config.h,
# parquet/parquet_version.h). We ship them as pre-generated and copy them into
# ${CMAKE_CURRENT_BINARY_DIR}/arrow/src/ so that include paths work.

set(_ARROW_GEN_INCDIR "${CMAKE_CURRENT_BINARY_DIR}/arrow/src")

# arrow/util/config.h
configure_file(
    "${CMAKE_CURRENT_SOURCE_DIR}/cmake/generated/arrow/util/config.h"
    "${_ARROW_GEN_INCDIR}/arrow/util/config.h"
    COPYONLY
)
# arrow/util/config_internal.h
configure_file(
    "${CMAKE_CURRENT_SOURCE_DIR}/cmake/generated/arrow/util/config_internal.h"
    "${_ARROW_GEN_INCDIR}/arrow/util/config_internal.h"
    COPYONLY
)
# parquet/parquet_version.h
configure_file(
    "${CMAKE_CURRENT_SOURCE_DIR}/cmake/generated/parquet/parquet_version.h"
    "${_ARROW_GEN_INCDIR}/parquet/parquet_version.h"
    COPYONLY
)

