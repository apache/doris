# curl
set(BUILD_CURL_EXE OFF CACHE BOOL "" FORCE)
set(BUILD_SHARED_LIBS OFF CACHE BOOL "" FORCE)
set(BUILD_TESTING OFF CACHE BOOL "" FORCE)
set(CURL_DISABLE_LDAP ON CACHE BOOL "" FORCE)
set(CURL_DISABLE_LDAPS ON CACHE BOOL "" FORCE)
set(CURL_USE_OPENSSL ON CACHE BOOL "" FORCE)
set(CMAKE_USE_LIBSSH2 OFF CACHE BOOL "" FORCE)
set(OPENSSL_ROOT_DIR ${TP_INSTALL_DIR} CACHE PATH "" FORCE)
add_subdirectory(${TP_SOURCE_DIR}/curl-8.2.1 ${CMAKE_CURRENT_BINARY_DIR}/curl EXCLUDE_FROM_ALL)
if(TARGET libcurl_static)
    add_library(curl ALIAS libcurl_static)
endif()
