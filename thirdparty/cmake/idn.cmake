# libidn — pure CMake build (no autoconf)
# Hand-written config.h replaces ./configure && make -C lib/gl.

set(IDN_SRC ${TP_SOURCE_DIR}/libidn-1.38)
set(IDN_CONFIG_DIR ${CMAKE_CURRENT_BINARY_DIR}/idn_config)
set(IDN_GEN_INC ${CMAKE_CURRENT_BINARY_DIR}/idn_gen_include)
file(MAKE_DIRECTORY ${IDN_CONFIG_DIR})
file(MAKE_DIRECTORY ${IDN_GEN_INC})

# gnulib ships unistr.h / unitypes.h as .in.h templates. Upstream's autotools
# build only prepends a "GENERATED" comment — no @VAR@ substitutions — so a
# straight file copy suffices.
configure_file(${IDN_SRC}/lib/gl/unistr.in.h   ${IDN_GEN_INC}/unistr.h   COPYONLY)
configure_file(${IDN_SRC}/lib/gl/unitypes.in.h ${IDN_GEN_INC}/unitypes.h COPYONLY)

# Generate idn-int.h (typically just stdint.h on modern Linux)
file(WRITE ${IDN_CONFIG_DIR}/idn-int.h
"/* Generated by CMake — idn-int.h for Linux */
#include <stdint.h>
")

