# libunwind — pure CMake build (no autoconf)
# Build for Linux x86_64 only. The L* files are "local" variants, G* are "generic".
# Both are needed: libunwind.a = local unwind, libunwind-x86_64.a = remote.

set(UNW_SRC ${TP_SOURCE_DIR}/libunwind-1.6.2)
set(UNW_CONFIG_DIR ${CMAKE_CURRENT_BINARY_DIR}/libunwind_config)
set(UNW_GEN_INCLUDE ${CMAKE_CURRENT_BINARY_DIR}/libunwind_gen_include)
file(MAKE_DIRECTORY ${UNW_CONFIG_DIR})
file(MAKE_DIRECTORY ${UNW_GEN_INCLUDE})

# libunwind-x86_64.h:129 includes <libunwind-common.h>, which upstream autoconf
# generates from libunwind-common.h.in (only @PKG_MAJOR/MINOR/EXTRA@ subs).
# External consumers transitively include this header, so emit it next to the
# public headers (UNW_GEN_INCLUDE is PUBLIC below); the internal config.h
# stays PRIVATE in UNW_CONFIG_DIR.
set(PKG_MAJOR "1")
set(PKG_MINOR "6")
set(PKG_EXTRA "")
configure_file(
    ${UNW_SRC}/include/libunwind-common.h.in
    ${UNW_GEN_INCLUDE}/libunwind-common.h
    @ONLY
)

