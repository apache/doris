# Pre-copy source headers so <sasl/sasl.h> is available
file(GLOB _CYRUS_SRC_HEADERS "${CYRUS_SASL_SRC}/include/*.h")
file(COPY ${_CYRUS_SRC_HEADERS} DESTINATION ${CYRUS_SASL_CONFIG_DIR}/sasl)

# ============================================================================
# 2. Source files
# ============================================================================

# Core library sources
set(SASL_CORE_SRCS
    ${CYRUS_SASL_SRC}/lib/auxprop.c
    ${CYRUS_SASL_SRC}/lib/canonusr.c
    ${CYRUS_SASL_SRC}/lib/checkpw.c
    ${CYRUS_SASL_SRC}/lib/client.c
    ${CYRUS_SASL_SRC}/lib/common.c
    ${CYRUS_SASL_SRC}/lib/config.c
    ${CYRUS_SASL_SRC}/lib/dlopen.c
    ${CYRUS_SASL_SRC}/lib/external.c
    ${CYRUS_SASL_SRC}/lib/md5.c
    ${CYRUS_SASL_SRC}/lib/saslutil.c
    ${CYRUS_SASL_SRC}/lib/server.c
    ${CYRUS_SASL_SRC}/lib/seterror.c
    ${CYRUS_SASL_SRC}/lib/snprintf.c
)

# Common plugin utilities
set(SASL_COMMON_SRCS
    ${CYRUS_SASL_SRC}/common/plugin_common.c
)

# Statically linked plugins
set(SASL_PLUGIN_SRCS
    # GSSAPI (requires MIT Kerberos)
    ${CYRUS_SASL_SRC}/plugins/gssapi.c
    ${CYRUS_SASL_SRC}/plugins/gssapiv2_init.c
    # PLAIN
    ${CYRUS_SASL_SRC}/plugins/plain.c
    ${CYRUS_SASL_SRC}/plugins/plain_init.c
    # ANONYMOUS
    ${CYRUS_SASL_SRC}/plugins/anonymous.c
    ${CYRUS_SASL_SRC}/plugins/anonymous_init.c
    # CRAM-MD5
    ${CYRUS_SASL_SRC}/plugins/cram.c
    ${CYRUS_SASL_SRC}/plugins/crammd5_init.c
    # DIGEST-MD5
    ${CYRUS_SASL_SRC}/plugins/digestmd5.c
    ${CYRUS_SASL_SRC}/plugins/digestmd5_init.c
    # SCRAM
    ${CYRUS_SASL_SRC}/plugins/scram.c
    ${CYRUS_SASL_SRC}/plugins/scram_init.c
    # LOGIN
    ${CYRUS_SASL_SRC}/plugins/login.c
    ${CYRUS_SASL_SRC}/plugins/login_init.c
)

# ============================================================================
# 3. Build libsasl2.a
# ============================================================================
add_library(_sasl2 STATIC
    ${SASL_CORE_SRCS}
    ${SASL_COMMON_SRCS}
    ${SASL_PLUGIN_SRCS}
)

target_include_directories(_sasl2
    PRIVATE ${CYRUS_SASL_CONFIG_DIR}         # config.h
    PRIVATE ${CYRUS_SASL_SRC}                # source root
    PRIVATE ${CYRUS_SASL_SRC}/include        # sasl.h, saslplug.h, etc.
    PRIVATE ${CYRUS_SASL_SRC}/common         # plugin_common.h
    PRIVATE ${CYRUS_SASL_SRC}/plugins        # plugin sources
    # OpenSSL headers
    PRIVATE ${SSL_SRC_FOR_SASL}/include
    PRIVATE ${CMAKE_CURRENT_BINARY_DIR}/openssl_config/include
    # KRB5/GSSAPI headers
    PRIVATE ${KRB5_SRC_FOR_SASL}/include
    PRIVATE ${KRB5_INCLUDE_FOR_SASL}
    PRIVATE ${KRB5_CONFIG_FOR_SASL}
    PRIVATE ${KRB5_ET_FOR_SASL}
    PRIVATE ${KRB5_SRC_FOR_SASL}/lib/gssapi/generic
    PRIVATE ${KRB5_SRC_FOR_SASL}/lib/gssapi/krb5
    PRIVATE ${KRB5_SRC_FOR_SASL}/util/et
    PUBLIC  ${CYRUS_SASL_CONFIG_DIR}         # <sasl/sasl.h>
)

target_compile_definitions(_sasl2 PRIVATE
    HAVE_CONFIG_H
    _GNU_SOURCE
    "PLUGINDIR=\"/usr/local/lib/sasl2\""
    "CONFIGDIR=\"/usr/local/lib/sasl2\""
)

target_compile_options(_sasl2 PRIVATE
    -fPIC -w
    -std=gnu89
    -Wno-implicit-function-declaration
)

target_link_libraries(_sasl2 PRIVATE
    $<TARGET_FILE:_crypto> $<TARGET_FILE:_ssl>
    pthread dl
)

# Depend on krb5 and openssl builds
add_dependencies(_sasl2
    krb5_static gssapi_krb5_static
    _crypto _ssl
)

# ============================================================================
# 4. Public interface
# ============================================================================
# Add public include for consumers (sasl/sasl.h)
target_include_directories(_sasl2 PUBLIC
    ${CYRUS_SASL_CONFIG_DIR}
    ${CYRUS_SASL_SRC}/include
)

# Public interface
add_library(cyrus-sasl ALIAS _sasl2)

# Compatibility target for downstream cmake files (e.g., rdkafka.cmake)
add_custom_target(cyrus_sasl_builder DEPENDS _sasl2)
