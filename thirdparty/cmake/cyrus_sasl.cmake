# cyrus-sasl — pure CMake build (no autoconf)
# Build libsasl2.a with statically linked plugins for GSSAPI, PLAIN, ANONYMOUS, CRAM-MD5, DIGEST-MD5, SCRAM.

set(CYRUS_SASL_SRC ${TP_SOURCE_DIR}/cyrus-sasl-2.1.27)
set(CYRUS_SASL_CONFIG_DIR ${CMAKE_CURRENT_BINARY_DIR}/cyrus_sasl_config)
file(MAKE_DIRECTORY ${CYRUS_SASL_CONFIG_DIR})
file(MAKE_DIRECTORY ${CYRUS_SASL_CONFIG_DIR}/sasl)

# KRB5 build dir for include path (from krb5.cmake)
set(KRB5_SRC_FOR_SASL ${TP_SOURCE_DIR}/krb5-1.19/src)
set(KRB5_INCLUDE_FOR_SASL ${CMAKE_CURRENT_BINARY_DIR}/krb5/include)
set(KRB5_CONFIG_FOR_SASL ${CMAKE_CURRENT_BINARY_DIR}/krb5/config)
set(KRB5_ET_FOR_SASL ${CMAKE_CURRENT_BINARY_DIR}/krb5/et_gen)

# OpenSSL include path (from openssl.cmake)
set(SSL_SRC_FOR_SASL ${TP_SOURCE_DIR}/openssl-OpenSSL_1_1_1s)

# ============================================================================
