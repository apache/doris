# libbacktrace - autoconf based, compile key sources directly
set(LIBBACKTRACE_SRC ${TP_SOURCE_DIR}/libbacktrace-2446c66076480ce07a6bd868badcbceb3eeecc2e)

# Generate config.h and backtrace-supported.h stubs in the build directory
set(_BACKTRACE_BUILD_DIR ${CMAKE_CURRENT_BINARY_DIR}/backtrace)
file(MAKE_DIRECTORY ${_BACKTRACE_BUILD_DIR})
file(WRITE ${_BACKTRACE_BUILD_DIR}/config.h
"/* config.h stub generated by cmake (replaces autoconf config.h) */
#define HAVE_DL_ITERATE_PHDR 1
#define HAVE_ATOMIC_FUNCTIONS 1
#define HAVE_DECL_STRNLEN 1
#define HAVE_LINK_H 1
#define _GNU_SOURCE 1
#define BACKTRACE_ELF_SIZE 64
#define BACKTRACE_SUPPORTS_THREADS 1
#define BACKTRACE_SUPPORTS_DATA 1
/* HAVE_MACH_O_DYLD_H intentionally not defined - Linux only */
")

# Generate backtrace-supported.h from template
set(BACKTRACE_SUPPORTED 1)
set(BACKTRACE_USES_MALLOC 0)
set(BACKTRACE_SUPPORTS_THREADS 1)
set(BACKTRACE_SUPPORTS_DATA 1)
configure_file(
    ${LIBBACKTRACE_SRC}/backtrace-supported.h.in
    ${_BACKTRACE_BUILD_DIR}/backtrace-supported.h
    @ONLY
)

add_library(backtrace STATIC
    ${LIBBACKTRACE_SRC}/backtrace.c
    ${LIBBACKTRACE_SRC}/dwarf.c
    ${LIBBACKTRACE_SRC}/elf.c
    ${LIBBACKTRACE_SRC}/fileline.c
    ${LIBBACKTRACE_SRC}/mmapio.c
    ${LIBBACKTRACE_SRC}/mmap.c
    ${LIBBACKTRACE_SRC}/posix.c
    ${LIBBACKTRACE_SRC}/print.c
    ${LIBBACKTRACE_SRC}/simple.c
    ${LIBBACKTRACE_SRC}/sort.c
    ${LIBBACKTRACE_SRC}/state.c
)
# Build dir first so config.h / backtrace-supported.h stubs are found
target_include_directories(backtrace PUBLIC ${_BACKTRACE_BUILD_DIR} ${LIBBACKTRACE_SRC})
target_compile_definitions(backtrace PRIVATE
    HAVE_DL_ITERATE_PHDR=1
    HAVE_ATOMIC_FUNCTIONS=1
    HAVE_DECL_STRNLEN=1
    HAVE_LINK_H=1
    _GNU_SOURCE=1
)
set_target_properties(backtrace PROPERTIES POSITION_INDEPENDENT_CODE ON)
