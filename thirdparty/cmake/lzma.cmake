    ${_LZMA_SRC}/src/liblzma/lzma/lzma_encoder_optimum_fast.c
    ${_LZMA_SRC}/src/liblzma/lzma/lzma_encoder_optimum_normal.c
    ${_LZMA_SRC}/src/liblzma/lzma/fastpos_table.c
    ${_LZMA_SRC}/src/liblzma/lzma/lzma_decoder.c
    ${_LZMA_SRC}/src/liblzma/lzma/lzma2_encoder.c
    ${_LZMA_SRC}/src/liblzma/lzma/lzma2_decoder.c
