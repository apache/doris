    ${_LZMA_SRC}/src/liblzma/lz/lz_encoder.c
    ${_LZMA_SRC}/src/liblzma/lz/lz_encoder_mf.c
    ${_LZMA_SRC}/src/liblzma/lz/lz_decoder.c
    # lzma
    ${_LZMA_SRC}/src/liblzma/lzma/lzma_encoder.c
