    ${_LZMA_SRC}/src/liblzma/common/index.c
    ${_LZMA_SRC}/src/liblzma/common/stream_flags_common.c
    ${_LZMA_SRC}/src/liblzma/common/vli_size.c
    # encoder
    ${_LZMA_SRC}/src/liblzma/common/alone_encoder.c
    ${_LZMA_SRC}/src/liblzma/common/block_buffer_encoder.c
    ${_LZMA_SRC}/src/liblzma/common/block_encoder.c
    ${_LZMA_SRC}/src/liblzma/common/block_header_encoder.c
    ${_LZMA_SRC}/src/liblzma/common/easy_buffer_encoder.c
    ${_LZMA_SRC}/src/liblzma/common/easy_encoder.c
    ${_LZMA_SRC}/src/liblzma/common/easy_encoder_memusage.c
    ${_LZMA_SRC}/src/liblzma/common/filter_buffer_encoder.c
    ${_LZMA_SRC}/src/liblzma/common/filter_encoder.c
    ${_LZMA_SRC}/src/liblzma/common/filter_flags_encoder.c
    ${_LZMA_SRC}/src/liblzma/common/index_encoder.c
    ${_LZMA_SRC}/src/liblzma/common/stream_buffer_encoder.c
    ${_LZMA_SRC}/src/liblzma/common/stream_encoder.c
    ${_LZMA_SRC}/src/liblzma/common/stream_flags_encoder.c
    ${_LZMA_SRC}/src/liblzma/common/vli_encoder.c
    # decoder
    ${_LZMA_SRC}/src/liblzma/common/alone_decoder.c
    ${_LZMA_SRC}/src/liblzma/common/auto_decoder.c
    ${_LZMA_SRC}/src/liblzma/common/block_buffer_decoder.c
    ${_LZMA_SRC}/src/liblzma/common/block_decoder.c
    ${_LZMA_SRC}/src/liblzma/common/block_header_decoder.c
    ${_LZMA_SRC}/src/liblzma/common/easy_decoder_memusage.c
    ${_LZMA_SRC}/src/liblzma/common/filter_buffer_decoder.c
    ${_LZMA_SRC}/src/liblzma/common/filter_decoder.c
    ${_LZMA_SRC}/src/liblzma/common/filter_flags_decoder.c
    ${_LZMA_SRC}/src/liblzma/common/index_decoder.c
    ${_LZMA_SRC}/src/liblzma/common/index_hash.c
    ${_LZMA_SRC}/src/liblzma/common/stream_buffer_decoder.c
