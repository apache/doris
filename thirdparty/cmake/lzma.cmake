    # tuklib
    ${_LZMA_SRC}/src/common/tuklib_physmem.c
    ${_LZMA_SRC}/src/common/tuklib_cpucores.c
)

add_library(_lzma STATIC ${_LZMA_SRCS})

target_include_directories(_lzma
    PRIVATE ${_LZMA_CONFIG_DIR}
    PRIVATE ${_LZMA_SRC}/src/liblzma/common
    PRIVATE ${_LZMA_SRC}/src/liblzma/check
    PRIVATE ${_LZMA_SRC}/src/liblzma/lz
    PRIVATE ${_LZMA_SRC}/src/liblzma/lzma
    PRIVATE ${_LZMA_SRC}/src/liblzma/rangecoder
    PRIVATE ${_LZMA_SRC}/src/liblzma/delta
    PRIVATE ${_LZMA_SRC}/src/liblzma/simple
    PRIVATE ${_LZMA_SRC}/src/common
    PUBLIC  ${_LZMA_SRC}/src/liblzma/api   # lzma.h
)

target_compile_definitions(_lzma PRIVATE
    HAVE_CONFIG_H
    _GNU_SOURCE
    TUKLIB_SYMBOL_PREFIX=lzma_
)

target_compile_options(_lzma PRIVATE -fPIC -w)
target_link_libraries(_lzma PRIVATE pthread)

add_library(lzma ALIAS _lzma)
