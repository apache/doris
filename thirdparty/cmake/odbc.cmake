# unixODBC — pure CMake build (no autoconf)
# Build ODBC driver manager only (DriverManager/) for static linking.

set(ODBC_SRC ${TP_SOURCE_DIR}/unixODBC-2.3.7)
set(ODBC_CONFIG_DIR ${CMAKE_CURRENT_BINARY_DIR}/odbc_config)
file(MAKE_DIRECTORY ${ODBC_CONFIG_DIR})
file(MAKE_DIRECTORY ${ODBC_CONFIG_DIR}/libltdl)

# Hand-written unixodbc_conf.h for Linux x86_64. Upstream creates this via
# `./configure` next to the source tree; BE's sqltypes.h:52 does
# `#include "unixodbc_conf.h"`, so it has to be reachable via include path.
# We emit into ODBC_CONFIG_DIR and propagate it as a PUBLIC include below;
# BE's CMakeLists.txt also adds it to BE's own include set.
file(WRITE ${ODBC_CONFIG_DIR}/unixodbc_conf.h
"/* unixodbc_conf.h — generated by CMake for Linux x86_64 (replaces autoconf) */
#ifndef HAVE_UNISTD_H
#define HAVE_UNISTD_H 1
#endif
#ifndef HAVE_PWD_H
#define HAVE_PWD_H 1
#endif
#ifndef HAVE_SYS_TIME_H
#define HAVE_SYS_TIME_H 1
#endif
#ifndef HAVE_LONG_LONG
#define HAVE_LONG_LONG 1
#endif
#ifndef SIZEOF_LONG_INT
#define SIZEOF_LONG_INT 8
#endif
")

