# ============================================================================
# 7. libkrb5support
# ============================================================================
file(GLOB KRB5SUPPORT_SRCS ${KRB5_SRC}/util/support/*.c)
list(FILTER KRB5SUPPORT_SRCS EXCLUDE REGEX "/t_[^/]*\\.c$")
# Exclude conditional files not needed on modern Linux (system provides these)
list(FILTER KRB5SUPPORT_SRCS EXCLUDE REGEX "/fnmatch\\.c$")
list(FILTER KRB5SUPPORT_SRCS EXCLUDE REGEX "/getopt\\.c$")
list(FILTER KRB5SUPPORT_SRCS EXCLUDE REGEX "/getopt_long\\.c$")
list(FILTER KRB5SUPPORT_SRCS EXCLUDE REGEX "/mkstemp\\.c$")
# Note: strlcpy.c provides krb5int_strlcpy() — keep it
list(FILTER KRB5SUPPORT_SRCS EXCLUDE REGEX "/gettimeofday\\.c$")
list(FILTER KRB5SUPPORT_SRCS EXCLUDE REGEX "/printf\\.c$")
list(FILTER KRB5SUPPORT_SRCS EXCLUDE REGEX "/secure_getenv\\.c$")
# Exclude IPC stream (Windows only)
list(FILTER KRB5SUPPORT_SRCS EXCLUDE REGEX "/ipc_stream\\.c$")

add_library(krb5support_static STATIC ${KRB5SUPPORT_SRCS})
target_include_directories(krb5support_static PRIVATE ${KRB5_COMMON_INCLUDES})
target_compile_options(krb5support_static PRIVATE ${KRB5_COMMON_COMPILE_OPTIONS})
target_compile_definitions(krb5support_static PRIVATE ${KRB5_COMMON_COMPILE_DEFINITIONS})
add_dependencies(krb5support_static krb5_generate_headers)
set_target_properties(krb5support_static PROPERTIES OUTPUT_NAME krb5support)

# ============================================================================
# 8. libcom_err
# ============================================================================
set(COM_ERR_SRCS
    ${KRB5_SRC}/util/et/com_err.c
    ${KRB5_SRC}/util/et/error_message.c
    ${KRB5_SRC}/util/et/et_name.c
)

add_library(com_err_static STATIC ${COM_ERR_SRCS})
target_include_directories(com_err_static PRIVATE ${KRB5_COMMON_INCLUDES})
target_compile_options(com_err_static PRIVATE ${KRB5_COMMON_COMPILE_OPTIONS})
target_compile_definitions(com_err_static PRIVATE ${KRB5_COMMON_COMPILE_DEFINITIONS})
target_link_libraries(com_err_static PRIVATE krb5support_static)
add_dependencies(com_err_static krb5_generate_headers)
set_target_properties(com_err_static PROPERTIES OUTPUT_NAME com_err)

# ============================================================================
# 8b. libprofile (profile configuration library)
# ============================================================================
file(GLOB PROFILE_SRCS ${KRB5_SRC}/util/profile/*.c)
# Exclude test files and tcl binding
list(FILTER PROFILE_SRCS EXCLUDE REGEX "/test_[^/]*\\.c$")
list(FILTER PROFILE_SRCS EXCLUDE REGEX "/profile_tcl\\.c$")
# Exclude macOS-specific file
list(FILTER PROFILE_SRCS EXCLUDE REGEX "/prof_FSp_glue\\.c$")
# Add generated prof_err.c
list(APPEND PROFILE_SRCS ${KRB5_ET_DIR}/prof_err.c)

add_library(profile_static STATIC ${PROFILE_SRCS})
target_include_directories(profile_static PRIVATE ${KRB5_COMMON_INCLUDES})
target_compile_options(profile_static PRIVATE ${KRB5_COMMON_COMPILE_OPTIONS})
target_compile_definitions(profile_static PRIVATE ${KRB5_COMMON_COMPILE_DEFINITIONS})
target_link_libraries(profile_static PRIVATE krb5support_static com_err_static)
add_dependencies(profile_static krb5_generate_headers)
set_target_properties(profile_static PROPERTIES OUTPUT_NAME profile)

# ============================================================================
# 9. libk5crypto
# ============================================================================
file(GLOB_RECURSE K5CRYPTO_SRCS ${KRB5_SRC}/lib/crypto/*.c)
# Exclude entire crypto_tests directory
list(FILTER K5CRYPTO_SRCS EXCLUDE REGEX "/crypto_tests/")
# Exclude deps directory
list(FILTER K5CRYPTO_SRCS EXCLUDE REGEX "/deps/")
# Exclude openssl backend (use builtin backend to avoid header conflicts)
list(FILTER K5CRYPTO_SRCS EXCLUDE REGEX "/crypto/openssl/")
# Exclude test files
list(FILTER K5CRYPTO_SRCS EXCLUDE REGEX "/t_[^/]*\\.c$")
list(FILTER K5CRYPTO_SRCS EXCLUDE REGEX "_test\\.c$")
list(FILTER K5CRYPTO_SRCS EXCLUDE REGEX "/destest\\.c$")

add_library(k5crypto_static STATIC ${K5CRYPTO_SRCS})
target_include_directories(k5crypto_static PRIVATE ${KRB5_COMMON_INCLUDES})
target_compile_options(k5crypto_static PRIVATE ${KRB5_COMMON_COMPILE_OPTIONS})
target_compile_definitions(k5crypto_static PRIVATE ${KRB5_COMMON_COMPILE_DEFINITIONS})
target_link_libraries(k5crypto_static PRIVATE krb5support_static com_err_static)
add_dependencies(k5crypto_static krb5_generate_headers)
set_target_properties(k5crypto_static PROPERTIES OUTPUT_NAME k5crypto)

# ============================================================================
# 10. libkrb5
# ============================================================================
file(GLOB_RECURSE KRB5_LIB_SRCS
    ${KRB5_SRC}/lib/krb5/krb/*.c
    ${KRB5_SRC}/lib/krb5/os/*.c
    ${KRB5_SRC}/lib/krb5/ccache/*.c
    ${KRB5_SRC}/lib/krb5/keytab/*.c
    ${KRB5_SRC}/lib/krb5/rcache/*.c
    ${KRB5_SRC}/lib/krb5/asn.1/*.c
    ${KRB5_SRC}/lib/krb5/unicode/*.c
    ${KRB5_SRC}/lib/krb5/posix/*.c
)
# Add krb5_libinit.c from the lib/krb5 root
list(APPEND KRB5_LIB_SRCS ${KRB5_SRC}/lib/krb5/krb5_libinit.c)
# Exclude test files
list(FILTER KRB5_LIB_SRCS EXCLUDE REGEX "/t_[^/]*\\.c$")
list(FILTER KRB5_LIB_SRCS EXCLUDE REGEX "_test\\.c$")
# Exclude strptime.c (BSD-specific; Linux has system strptime via HAVE_STRPTIME)
list(FILTER KRB5_LIB_SRCS EXCLUDE REGEX "/strptime\\.c$")
# Exclude brand.c (version branding, uses generated patchlevel — not needed for library)
list(FILTER KRB5_LIB_SRCS EXCLUDE REGEX "/brand\\.c$")
# Exclude ucgendat.c (code generator tool, not library code; has main())
list(FILTER KRB5_LIB_SRCS EXCLUDE REGEX "/ucgendat\\.c$")
# Exclude deps directories
list(FILTER KRB5_LIB_SRCS EXCLUDE REGEX "/deps/")
# Add generated error table .c files for krb5
list(APPEND KRB5_LIB_SRCS ${KRB5_ET_C_FOR_KRB5})

add_library(krb5_static STATIC ${KRB5_LIB_SRCS})
target_include_directories(krb5_static PRIVATE ${KRB5_COMMON_INCLUDES})
target_compile_options(krb5_static PRIVATE ${KRB5_COMMON_COMPILE_OPTIONS})
target_compile_definitions(krb5_static PRIVATE ${KRB5_COMMON_COMPILE_DEFINITIONS})
target_link_libraries(krb5_static PRIVATE krb5support_static com_err_static k5crypto_static profile_static)
add_dependencies(krb5_static krb5_generate_headers)
set_target_properties(krb5_static PROPERTIES OUTPUT_NAME krb5)

# ============================================================================
# 11. libgssapi_krb5
# ============================================================================
file(GLOB_RECURSE GSSAPI_SRCS
    ${KRB5_SRC}/lib/gssapi/krb5/*.c
    ${KRB5_SRC}/lib/gssapi/generic/*.c
    ${KRB5_SRC}/lib/gssapi/mechglue/*.c
)
# Exclude test files
list(FILTER GSSAPI_SRCS EXCLUDE REGEX "/t_[^/]*\\.c$")
list(FILTER GSSAPI_SRCS EXCLUDE REGEX "_test\\.c$")
# Exclude deps directories
list(FILTER GSSAPI_SRCS EXCLUDE REGEX "/deps/")
# Exclude maptest.c (test driver with main())
list(FILTER GSSAPI_SRCS EXCLUDE REGEX "/maptest\\.c$")
# Add generated error table .c files for gssapi
list(APPEND GSSAPI_SRCS ${KRB5_ET_C_FOR_GSSAPI})

add_library(gssapi_krb5_static STATIC ${GSSAPI_SRCS})
target_include_directories(gssapi_krb5_static PRIVATE ${KRB5_COMMON_INCLUDES})
target_compile_options(gssapi_krb5_static PRIVATE ${KRB5_COMMON_COMPILE_OPTIONS})
target_compile_definitions(gssapi_krb5_static PRIVATE ${KRB5_COMMON_COMPILE_DEFINITIONS})
target_link_libraries(gssapi_krb5_static PRIVATE
    krb5support_static com_err_static k5crypto_static krb5_static)
add_dependencies(gssapi_krb5_static krb5_generate_headers)
set_target_properties(gssapi_krb5_static PROPERTIES OUTPUT_NAME gssapi_krb5)

# ============================================================================
# 12. Public interface: add PUBLIC include dirs and create ALIAS targets
# ============================================================================
set(KRB5_PUBLIC_INCLUDE_DIRS
    ${KRB5_SRC}/include
    ${KRB5_INCLUDE_DIR}
    ${KRB5_CONFIG_DIR}
    ${KRB5_ET_DIR}
)

# Add public includes to all static targets
foreach(_tgt krb5support_static com_err_static k5crypto_static krb5_static gssapi_krb5_static)
    target_include_directories(${_tgt} PUBLIC ${KRB5_PUBLIC_INCLUDE_DIRS})
endforeach()

# Link system libraries
target_link_libraries(krb5support_static PUBLIC pthread dl)
target_link_libraries(krb5_static PUBLIC resolv)

# Public ALIAS targets matching the names expected by consumers
add_library(krb5support ALIAS krb5support_static)
add_library(com_err ALIAS com_err_static)
add_library(k5crypto ALIAS k5crypto_static)
add_library(krb5 ALIAS krb5_static)
add_library(gssapi_krb5 ALIAS gssapi_krb5_static)
