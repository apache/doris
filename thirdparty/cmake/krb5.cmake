# ============================================================================
# 2. Generate osconf.h from osconf.hin
# ============================================================================
file(READ ${KRB5_SRC}/include/osconf.hin OSCONF_CONTENT)
# Replace longer tokens first to avoid substring conflicts (e.g. @SBINDIR before @BINDIR)
string(REPLACE "@KRB5RCTMPDIR" "/tmp" OSCONF_CONTENT "${OSCONF_CONTENT}")
string(REPLACE "@GSSMODULEDIR" "/usr/local/lib/gss" OSCONF_CONTENT "${OSCONF_CONTENT}")
string(REPLACE "@MODULEDIR" "/usr/local/lib/krb5/plugins" OSCONF_CONTENT "${OSCONF_CONTENT}")
string(REPLACE "@LOCALSTATEDIR" "/usr/local/var" OSCONF_CONTENT "${OSCONF_CONTENT}")
string(REPLACE "@RUNSTATEDIR" "/usr/local/var/run" OSCONF_CONTENT "${OSCONF_CONTENT}")
string(REPLACE "@SBINDIR" "/usr/local/sbin" OSCONF_CONTENT "${OSCONF_CONTENT}")
string(REPLACE "@BINDIR" "/usr/local/bin" OSCONF_CONTENT "${OSCONF_CONTENT}")
string(REPLACE "@LIBDIR" "/usr/local/lib" OSCONF_CONTENT "${OSCONF_CONTENT}")
string(REPLACE "@SYSCONFCONF" "" OSCONF_CONTENT "${OSCONF_CONTENT}")
string(REPLACE "@SYSCONFDIR" "/usr/local/etc" OSCONF_CONTENT "${OSCONF_CONTENT}")
string(REPLACE "@DYNOBJEXT" ".so" OSCONF_CONTENT "${OSCONF_CONTENT}")
file(WRITE ${KRB5_CONFIG_DIR}/osconf.h "${OSCONF_CONTENT}")

# ============================================================================
# 3. Generate krb5/krb5.h (will be done after error tables are generated)
#    Generate gssapi/gssapi.h and copy companion headers
# ============================================================================

# Generate prof_err.h at configure time (needed by krb5 sources that use PROF_* constants)
execute_process(
    COMMAND awk -f ${KRB5_SRC}/util/et/et_h.awk "outfile=${KRB5_INCLUDE_DIR}/prof_err.h"
            ${KRB5_SRC}/util/profile/prof_err.et
)

# profile.h: copy from profile.hin and append prof_err.h include
file(READ ${KRB5_SRC}/util/profile/profile.hin _PROFILE_CONTENT)
file(WRITE ${KRB5_INCLUDE_DIR}/profile.h "${_PROFILE_CONTENT}\n#include \"prof_err.h\"\n")

# gssapi/gssapi.h: prologue + gssapi.hin content
file(READ ${KRB5_SRC}/lib/gssapi/generic/gssapi.hin GSSAPI_HIN_CONTENT)
file(WRITE ${KRB5_INCLUDE_DIR}/gssapi/gssapi.h
"/* This is the gssapi.h prologue. */\n/* End of gssapi.h prologue. */\n${GSSAPI_HIN_CONTENT}")

# Generate errmap.h and error_map.h (pre-generated, no perl dependency)
# These are deterministic output from gen.pl/gen-map.pl for krb5-1.19.
file(READ ${CMAKE_CURRENT_SOURCE_DIR}/cmake/krb5_errmap.h.inc _ERRMAP_CONTENT)
file(WRITE ${KRB5_ET_DIR}/errmap.h "${_ERRMAP_CONTENT}")
file(READ ${CMAKE_CURRENT_SOURCE_DIR}/cmake/krb5_error_map.h.inc _ERROR_MAP_CONTENT)
file(WRITE ${KRB5_ET_DIR}/error_map.h "${_ERROR_MAP_CONTENT}")

# Copy companion gssapi headers
file(COPY ${KRB5_SRC}/lib/gssapi/generic/gssapi_generic.h DESTINATION ${KRB5_INCLUDE_DIR}/gssapi)
file(COPY ${KRB5_SRC}/lib/gssapi/generic/gssapi_alloc.h DESTINATION ${KRB5_INCLUDE_DIR}/gssapi)
file(COPY ${KRB5_SRC}/lib/gssapi/generic/gssapi_ext.h DESTINATION ${KRB5_INCLUDE_DIR}/gssapi)
file(COPY ${KRB5_SRC}/lib/gssapi/krb5/gssapi_krb5.h DESTINATION ${KRB5_INCLUDE_DIR}/gssapi)

# ============================================================================
# 4. Error table generation using AWK
# ============================================================================
set(ET_AWK_C ${KRB5_SRC}/util/et/et_c.awk)
set(ET_AWK_H ${KRB5_SRC}/util/et/et_h.awk)

# Error table definitions: name -> source .et file
set(KRB5_ET_TABLES
    asn1_err    ${KRB5_SRC}/lib/krb5/error_tables/asn1_err.et
    kdb5_err    ${KRB5_SRC}/lib/krb5/error_tables/kdb5_err.et
    krb5_err    ${KRB5_SRC}/lib/krb5/error_tables/krb5_err.et
    k5e1_err    ${KRB5_SRC}/lib/krb5/error_tables/k5e1_err.et
    kv5m_err    ${KRB5_SRC}/lib/krb5/error_tables/kv5m_err.et
    krb524_err  ${KRB5_SRC}/lib/krb5/error_tables/krb524_err.et
    gssapi_err_krb5     ${KRB5_SRC}/lib/gssapi/krb5/gssapi_err_krb5.et
    gssapi_err_generic  ${KRB5_SRC}/lib/gssapi/generic/gssapi_err_generic.et
    prof_err            ${KRB5_SRC}/util/profile/prof_err.et
)

set(KRB5_ET_GENERATED_C "")
set(KRB5_ET_GENERATED_H "")
set(KRB5_ET_KRB5_HEADERS "")

list(LENGTH KRB5_ET_TABLES _et_len)
math(EXPR _et_last "${_et_len} - 1")
set(_et_idx 0)
while(_et_idx LESS ${_et_len})
    list(GET KRB5_ET_TABLES ${_et_idx} _et_name)
    math(EXPR _et_src_idx "${_et_idx} + 1")
    list(GET KRB5_ET_TABLES ${_et_src_idx} _et_file)

    set(_et_c ${KRB5_ET_DIR}/${_et_name}.c)
    set(_et_h ${KRB5_ET_DIR}/${_et_name}.h)

    add_custom_command(
        OUTPUT ${_et_c}
        COMMAND awk -f ${ET_AWK_C} "outfile=${_et_c}" "textdomain=" "localedir=" ${_et_file}
        DEPENDS ${_et_file} ${ET_AWK_C}
        COMMENT "Generating ${_et_name}.c from error table"
    )
    add_custom_command(
        OUTPUT ${_et_h}
        COMMAND awk -f ${ET_AWK_H} "outfile=${_et_h}" ${_et_file}
        DEPENDS ${_et_file} ${ET_AWK_H}
        COMMENT "Generating ${_et_name}.h from error table"
    )

    list(APPEND KRB5_ET_GENERATED_C ${_et_c})
    list(APPEND KRB5_ET_GENERATED_H ${_et_h})

    # Track which headers belong to the krb5 error tables (for krb5.h generation)
    if(_et_name STREQUAL "asn1_err" OR
       _et_name STREQUAL "kdb5_err" OR
       _et_name STREQUAL "krb5_err" OR
       _et_name STREQUAL "k5e1_err" OR
       _et_name STREQUAL "kv5m_err" OR
       _et_name STREQUAL "krb524_err")
        list(APPEND KRB5_ET_KRB5_HEADERS ${_et_h})
    endif()

    math(EXPR _et_idx "${_et_idx} + 2")
endwhile()

# Separate error table .c files by library
set(KRB5_ET_C_FOR_KRB5 "")
set(KRB5_ET_C_FOR_GSSAPI "")
foreach(_c ${KRB5_ET_GENERATED_C})
    get_filename_component(_name ${_c} NAME_WE)
    if(_name MATCHES "^gssapi_err")
        list(APPEND KRB5_ET_C_FOR_GSSAPI ${_c})
    else()
        list(APPEND KRB5_ET_C_FOR_KRB5 ${_c})
    endif()
endforeach()

# ============================================================================
# 5. Generate krb5/krb5.h by concatenating krb5.hin + error table headers
#    This must be a custom command since it depends on generated .h files.
# ============================================================================
set(KRB5_KRB5_H ${KRB5_INCLUDE_DIR}/krb5/krb5.h)

# Write a helper shell script that concatenates krb5.hin + error table headers into krb5.h.
# Using a shell script avoids CMake -P semicolon issues with Ninja.
set(_KRB5_H_SCRIPT "${CMAKE_CURRENT_BINARY_DIR}/krb5_gen_header.sh")

# Build the list of input files for krb5.h concatenation
set(_krb5_h_inputs "${KRB5_SRC}/include/krb5/krb5.hin")
foreach(_eh ${KRB5_ET_KRB5_HEADERS})
    list(APPEND _krb5_h_inputs "${_eh}")
endforeach()

# Write a CMake -P script that concatenates files (no bash dependency)
set(_KRB5_H_GEN_SCRIPT "${CMAKE_CURRENT_BINARY_DIR}/krb5_gen_header.cmake")
set(_input_reads "")
foreach(_f ${_krb5_h_inputs})
    string(APPEND _input_reads "file(READ \"${_f}\" _tmp)\nfile(APPEND \"${KRB5_KRB5_H}\" \"\${_tmp}\")\n")
endforeach()
file(WRITE ${_KRB5_H_GEN_SCRIPT}
"file(WRITE \"${KRB5_KRB5_H}\" \"/* Generated — do not edit. */\\n#ifndef KRB5_KRB5_H_INCLUDED\\n#define KRB5_KRB5_H_INCLUDED\\n\")\n${_input_reads}file(APPEND \"${KRB5_KRB5_H}\" \"#endif /* KRB5_KRB5_H_INCLUDED */\\n\")\n")

add_custom_command(
    OUTPUT ${KRB5_KRB5_H}
    COMMAND ${CMAKE_COMMAND} -P ${_KRB5_H_GEN_SCRIPT}
    DEPENDS ${KRB5_SRC}/include/krb5/krb5.hin ${KRB5_ET_KRB5_HEADERS}
    COMMENT "Generating krb5/krb5.h"
)

add_custom_target(krb5_generate_headers DEPENDS ${KRB5_ET_GENERATED_H} ${KRB5_KRB5_H})

