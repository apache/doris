#define LIBXML_PATTERN_ENABLED 1
#define LIBXML_PUSH_ENABLED 1
#define LIBXML_READER_ENABLED 1
#define LIBXML_REGEXP_ENABLED 1
#define LIBXML_SAX1_ENABLED 1
#define LIBXML_SCHEMAS_ENABLED 1
#define LIBXML_SCHEMATRON_ENABLED 1
