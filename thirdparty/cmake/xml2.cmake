# libxml2 — pure CMake build (no autoconf)
# Build a minimal libxml2 without python/iconv/lzma per original configure flags.

set(_XML2_SRC "${TP_SOURCE_DIR}/libxml2-v2.9.10")
set(_XML2_CONFIG_DIR "${CMAKE_CURRENT_BINARY_DIR}/xml2_config")
file(MAKE_DIRECTORY ${_XML2_CONFIG_DIR})
file(MAKE_DIRECTORY ${_XML2_CONFIG_DIR}/include/libxml)

# Generate xmlversion.h
set(VERSION "2.9.10")
set(LIBXML_VERSION_NUMBER 20910)
set(LIBXML_VERSION_EXTRA "")
set(WITH_TRIO 0)
set(WITH_THREADS 1)
set(WITH_THREAD_ALLOC 0)
set(WITH_TREE 1)
set(WITH_OUTPUT 1)
set(WITH_PUSH 1)
set(WITH_READER 1)
set(WITH_PATTERN 1)
set(WITH_WRITER 1)
set(WITH_SAX1 1)
set(WITH_FTP 1)
set(WITH_HTTP 1)
set(WITH_VALID 1)
set(WITH_HTML 1)
set(WITH_LEGACY 1)
set(WITH_C14N 1)
set(WITH_CATALOG 1)
set(WITH_DOCB 1)
set(WITH_XPATH 1)
set(WITH_XPTR 1)
set(WITH_XINCLUDE 1)
set(WITH_ICONV 0)
set(WITH_ICU 0)
set(WITH_ISO8859X 0)
set(WITH_DEBUG 1)
set(WITH_MEM_DEBUG 0)
set(WITH_RUN_DEBUG 0)
set(WITH_REGEXPS 1)
set(WITH_SCHEMAS 1)
set(WITH_SCHEMATRON 1)
set(WITH_MODULES 1)
set(MODULE_EXTENSION ".so")
set(WITH_ZLIB 1)
set(WITH_LZMA 0)

configure_file(
    "${_XML2_SRC}/include/libxml/xmlversion.h.in"
    "${_XML2_CONFIG_DIR}/include/libxml/xmlversion.h"
    @ONLY
)

# Generate config.h
