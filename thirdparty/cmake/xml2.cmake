# Library source files only (exclude test* and run* programs)
set(_XML2_SRCS
    ${_XML2_SRC}/buf.c
    ${_XML2_SRC}/c14n.c
    ${_XML2_SRC}/catalog.c
    ${_XML2_SRC}/chvalid.c
    ${_XML2_SRC}/debugXML.c
    ${_XML2_SRC}/dict.c
    ${_XML2_SRC}/DOCBparser.c
    ${_XML2_SRC}/encoding.c
    ${_XML2_SRC}/entities.c
    ${_XML2_SRC}/error.c
    ${_XML2_SRC}/globals.c
    ${_XML2_SRC}/hash.c
    ${_XML2_SRC}/HTMLparser.c
    ${_XML2_SRC}/HTMLtree.c
    ${_XML2_SRC}/legacy.c
    ${_XML2_SRC}/list.c
    ${_XML2_SRC}/nanoftp.c
    ${_XML2_SRC}/nanohttp.c
    ${_XML2_SRC}/parser.c
    ${_XML2_SRC}/parserInternals.c
    ${_XML2_SRC}/pattern.c
    ${_XML2_SRC}/relaxng.c
    ${_XML2_SRC}/SAX.c
    ${_XML2_SRC}/SAX2.c
    ${_XML2_SRC}/schematron.c
    ${_XML2_SRC}/threads.c
    ${_XML2_SRC}/tree.c
    ${_XML2_SRC}/uri.c
    ${_XML2_SRC}/valid.c
    ${_XML2_SRC}/xinclude.c
    ${_XML2_SRC}/xlink.c
    ${_XML2_SRC}/xmlIO.c
    ${_XML2_SRC}/xmlmemory.c
    ${_XML2_SRC}/xmlmodule.c
    ${_XML2_SRC}/xmlreader.c
    ${_XML2_SRC}/xmlregexp.c
    ${_XML2_SRC}/xmlsave.c
    ${_XML2_SRC}/xmlschemas.c
    ${_XML2_SRC}/xmlschemastypes.c
    ${_XML2_SRC}/xmlstring.c
    ${_XML2_SRC}/xmlunicode.c
    ${_XML2_SRC}/xmlwriter.c
    ${_XML2_SRC}/xpath.c
    ${_XML2_SRC}/xpointer.c
    ${_XML2_SRC}/xzlib.c
)

add_library(_xml2 STATIC ${_XML2_SRCS})

target_include_directories(_xml2
    PRIVATE ${_XML2_CONFIG_DIR}
    PRIVATE ${_XML2_SRC}                # for libxml/ internal headers
    PUBLIC  ${_XML2_SRC}/include         # libxml/xmlversion.h, tree.h, etc.
    PUBLIC  ${_XML2_CONFIG_DIR}/include
)

target_compile_definitions(_xml2 PRIVATE
    HAVE_CONFIG_H
    _GNU_SOURCE
    _REENTRANT
)

target_compile_options(_xml2 PRIVATE -fPIC -w)
target_link_libraries(_xml2 PRIVATE pthread dl)
set_target_properties(_xml2 PROPERTIES ARCHIVE_OUTPUT_DIRECTORY "${CMAKE_BINARY_DIR}/lib")

# Link zlib if available
if(TARGET libz OR TARGET z)
    target_link_libraries(_xml2 PRIVATE $<IF:$<TARGET_EXISTS:libz>,libz,z>)
endif()

add_library(xml2 ALIAS _xml2)

# Set variables for find_package(LibXml2)
set(LIBXML2_FOUND TRUE CACHE BOOL "" FORCE)
set(LIBXML2_INCLUDE_DIR "${_XML2_SRC}/include;${_XML2_CONFIG_DIR}/include" CACHE PATH "" FORCE)
set(LIBXML2_LIBRARY "${CMAKE_BINARY_DIR}/lib/lib_xml2.a" CACHE FILEPATH "" FORCE)
set(LIBXML2_LIBRARIES "${CMAKE_BINARY_DIR}/lib/lib_xml2.a" CACHE STRING "" FORCE)
