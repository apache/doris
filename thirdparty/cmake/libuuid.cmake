# libuuid — pure CMake build (no autoconf)
# Replaces execute_process(./configure && make) with direct add_library.

set(UUID_SRC ${TP_SOURCE_DIR}/libuuid-1.0.3)
set(UUID_CONFIG_DIR ${CMAKE_CURRENT_BINARY_DIR}/libuuid)
file(MAKE_DIRECTORY ${UUID_CONFIG_DIR})

# Generate config.h — hardcode Linux values (all Doris targets are Linux x86_64/aarch64)
file(WRITE ${UUID_CONFIG_DIR}/config.h
"/* Generated by CMake — libuuid config for Linux */
#define HAVE_DECL__SC_HOST_NAME_MAX 1
#define HAVE_DLFCN_H 1
#define HAVE_FCNTL_H 1
#define HAVE_FTRUNCATE 1
#define HAVE_GETTIMEOFDAY 1
#define HAVE_INTTYPES_H 1
#define HAVE_LIMITS_H 1
#define HAVE_MEMORY_H 1
#define HAVE_MEMSET 1
#define HAVE_NETINET_IN_H 1
#define HAVE_SOCKET 1
#define HAVE_SRANDOM 1
#define HAVE_STDINT_H 1
#define HAVE_STDLIB_H 1
#define HAVE_STRINGS_H 1
#define HAVE_STRING_H 1
#define HAVE_STRTOUL 1
#define HAVE_SYS_FILE_H 1
#define HAVE_SYS_IOCTL_H 1
#define HAVE_SYS_SOCKET_H 1
#define HAVE_SYS_STAT_H 1
#define HAVE_SYS_TIME_H 1
#define HAVE_SYS_TYPES_H 1
#define HAVE_UNISTD_H 1
#define HAVE_USLEEP 1
#define HAVE_NET_IF_H 1
#define HAVE_SYS_SYSCALL_H 1
#define HAVE_JRAND48 1
#define HAVE_ERR_H 1
#define HAVE_LOFF_T 1
#define HAVE_TLS 1
#define HAVE_PROGRAM_INVOCATION_SHORT_NAME 1
#define STDC_HEADERS 1
#define PACKAGE \"libuuid\"
#define PACKAGE_VERSION \"1.0.3\"
#define PACKAGE_STRING \"libuuid 1.0.3\"
")

add_library(_libuuid STATIC
    ${UUID_SRC}/clear.c
    ${UUID_SRC}/compare.c
    ${UUID_SRC}/copy.c
    ${UUID_SRC}/gen_uuid.c
    ${UUID_SRC}/isnull.c
    ${UUID_SRC}/pack.c
    ${UUID_SRC}/parse.c
    ${UUID_SRC}/randutils.c
    ${UUID_SRC}/unpack.c
    ${UUID_SRC}/unparse.c
    ${UUID_SRC}/uuid_time.c
)

target_include_directories(_libuuid
    PRIVATE ${UUID_CONFIG_DIR}   # for config.h
    PRIVATE ${UUID_SRC}          # for internal headers (c.h, uuidP.h, etc.)
    PUBLIC  ${UUID_SRC}          # for uuid.h (public API)
)

target_compile_definitions(_libuuid PRIVATE
    HAVE_CONFIG_H
    _GNU_SOURCE
)

target_compile_options(_libuuid PRIVATE -fPIC -w)

add_library(libuuid ALIAS _libuuid)
