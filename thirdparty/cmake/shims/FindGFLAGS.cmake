# Find module shim for GFLAGS
# gflags is built via add_subdirectory
if(TARGET gflags_nothreads_static OR TARGET gflags_static OR TARGET gflags)
    set(GFLAGS_FOUND TRUE)
    set(gflags_FOUND TRUE)
    get_target_property(_gflags_src_dir gflags_nothreads_static SOURCE_DIR)
    if(NOT _gflags_src_dir)
        get_target_property(_gflags_src_dir gflags_static SOURCE_DIR)
    endif()
    set(GFLAGS_INCLUDE_DIR "${_gflags_src_dir}/src")
    set(GFLAGS_INCLUDE_DIRS "${GFLAGS_INCLUDE_DIR}")
    if(TARGET gflags_nothreads_static)
        set(GFLAGS_LIBRARIES gflags_nothreads_static)
        set(GFLAGS_LIBRARY gflags_nothreads_static)
    elseif(TARGET gflags_static)
        set(GFLAGS_LIBRARIES gflags_static)
        set(GFLAGS_LIBRARY gflags_static)
    endif()
    include(FindPackageHandleStandardArgs)
    find_package_handle_standard_args(GFLAGS DEFAULT_MSG GFLAGS_LIBRARY GFLAGS_INCLUDE_DIR)
endif()
