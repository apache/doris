# Find module shim for Protobuf
# protobuf is built via add_subdirectory, targets already exist
if(TARGET libprotobuf)
    get_target_property(_pb_src_dir libprotobuf SOURCE_DIR)
    # protobuf SOURCE_DIR is .../protobuf-21.11/cmake, headers are in ../src
    get_filename_component(_pb_root "${_pb_src_dir}" DIRECTORY)
    get_target_property(_pb_bin_dir libprotobuf BINARY_DIR)
    set(Protobuf_FOUND TRUE)
    set(PROTOBUF_FOUND TRUE)
    set(Protobuf_INCLUDE_DIR "${_pb_root}/src")
    set(Protobuf_INCLUDE_DIRS "${_pb_root}/src")
    set(PROTOBUF_INCLUDE_DIR "${_pb_root}/src")
    set(PROTOBUF_INCLUDE_DIRS "${_pb_root}/src")
    set(Protobuf_LIBRARIES libprotobuf)
    set(Protobuf_LIBRARY libprotobuf)
    set(PROTOBUF_LIBRARY "${_pb_bin_dir}/libprotobuf.a")
    set(PROTOBUF_STATIC_LIB "${_pb_bin_dir}/libprotobuf.a")
    set(Protobuf_LITE_LIBRARIES libprotobuf-lite)
    set(Protobuf_VERSION "3.21.11")
    # protoc
    if(TARGET protoc)
        set(Protobuf_PROTOC_EXECUTABLE "$<TARGET_FILE:protoc>")
        set(PROTOBUF_PROTOC_EXECUTABLE "$<TARGET_FILE:protoc>")
    endif()
    if(TARGET libprotoc)
        get_target_property(_protoc_bin_dir libprotoc BINARY_DIR)
        set(PROTOC_LIBRARY "${_protoc_bin_dir}/libprotoc.a")
        set(PROTOC_STATIC_LIB "${_protoc_bin_dir}/libprotoc.a")
        set(PROTOBUF_EXECUTABLE "$<TARGET_FILE:protoc>")
    endif()
    include(FindPackageHandleStandardArgs)
    find_package_handle_standard_args(Protobuf DEFAULT_MSG Protobuf_LIBRARIES Protobuf_INCLUDE_DIR)
    # Create imported targets that some projects expect
    if(NOT TARGET protobuf::libprotobuf)
        add_library(protobuf::libprotobuf ALIAS libprotobuf)
    endif()
    if(TARGET libprotobuf-lite AND NOT TARGET protobuf::libprotobuf-lite)
        add_library(protobuf::libprotobuf-lite ALIAS libprotobuf-lite)
    endif()
    if(TARGET protoc AND NOT TARGET protobuf::protoc)
        add_library(protobuf::protoc ALIAS libprotoc)
    endif()
endif()

