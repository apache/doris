# --- Generate composite jemalloc.h ---
# Read processed sub-headers
file(READ "${JE_CONFIG_DIR}/jemalloc/jemalloc_defs.h" _DEFS)
file(READ "${JE_CONFIG_DIR}/jemalloc/jemalloc_rename.h" _RENAME)
file(READ "${JE_CONFIG_DIR}/jemalloc/jemalloc_macros.h" _MACROS)
file(READ "${JE_CONFIG_DIR}/jemalloc/jemalloc_protos.h" _PROTOS)
file(READ "${JE_CONFIG_DIR}/jemalloc/jemalloc_typedefs.h" _TYPEDEFS)
file(READ "${JE_CONFIG_DIR}/jemalloc/jemalloc_mangle.h" _MANGLE)
file(WRITE "${JE_CONFIG_DIR}/jemalloc/jemalloc.h"
"#ifndef JEMALLOC_H_
#define JEMALLOC_H_
#ifdef __cplusplus
extern \"C\" {
#endif

${_DEFS}
${_RENAME}
${_MACROS}
${_PROTOS}
${_TYPEDEFS}
${_MANGLE}
#ifdef __cplusplus
}
#endif
#endif /* JEMALLOC_H_ */
")

# Collect jemalloc source files
file(GLOB JE_SRCS "${JE_SRC}/src/*.c")

# Remove OS-specific files
list(FILTER JE_SRCS EXCLUDE REGEX "zone\\.c")

add_library(_jemalloc STATIC ${JE_SRCS})

target_include_directories(_jemalloc
    PRIVATE ${JE_CONFIG_DIR}
    PRIVATE ${JE_CONFIG_DIR}/jemalloc/internal
    PRIVATE ${JE_SRC}/include
    PRIVATE ${JE_SRC}/include/jemalloc/internal
    PUBLIC  ${JE_CONFIG_DIR}
    PUBLIC  ${JE_SRC}/include
)

target_compile_definitions(_jemalloc PRIVATE
    JEMALLOC_NO_PRIVATE_NAMESPACE
    _GNU_SOURCE
    _REENTRANT
)

target_compile_options(_jemalloc PRIVATE -fPIC -w -funroll-loops)
target_link_libraries(_jemalloc PRIVATE pthread dl m)

add_library(jemalloc ALIAS _jemalloc)
