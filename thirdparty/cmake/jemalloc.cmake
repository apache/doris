# jemalloc — pure CMake build (no autoconf)
# Build jemalloc with Doris-specific prefix (je) and install suffix (_doris).
# Hand-written config headers replace ./configure.

# MSAN: skip jemalloc. compiler-rt's MSAN runtime ships its own allocator
# (MsanAllocate + sanitizer_common SizeClassAllocator) and intercepts malloc/free;
# jemalloc's metadata/freelists would recurse through MSAN shadow tracking.
# ClickHouse takes the same approach in contrib/jemalloc-cmake/CMakeLists.txt.
# USE_JEMALLOC=OFF in be/CMakeLists.txt already prevents linking; this skips
# compilation too. Dummy INTERFACE target keeps COMMON_THIRDPARTY's `jemalloc`
# reference resolvable.
if ("${CMAKE_BUILD_TYPE}" STREQUAL "MSAN")
    message(STATUS "MSAN: skipping jemalloc (sanitizer runtime provides allocator)")
    add_library(jemalloc INTERFACE)
    return()
endif()

set(JE_SRC ${TP_SOURCE_DIR}/jemalloc-5.3.0)
set(JE_CONFIG_DIR ${CMAKE_CURRENT_BINARY_DIR}/jemalloc_config)
file(MAKE_DIRECTORY ${JE_CONFIG_DIR}/jemalloc)
file(MAKE_DIRECTORY ${JE_CONFIG_DIR}/jemalloc/internal)

# Detect page size at configure time (needed for jemalloc)
execute_process(COMMAND getconf PAGESIZE
    OUTPUT_VARIABLE JE_PAGE_SIZE OUTPUT_STRIP_TRAILING_WHITESPACE)
if(NOT JE_PAGE_SIZE)
    set(JE_PAGE_SIZE 4096)
endif()
# LG_PAGE = log2(PAGE_SIZE)
math(EXPR JE_LG_PAGE "0")
set(_ps ${JE_PAGE_SIZE})
while(_ps GREATER 1)
    math(EXPR _ps "${_ps} / 2")
    math(EXPR JE_LG_PAGE "${JE_LG_PAGE} + 1")
endwhile()

