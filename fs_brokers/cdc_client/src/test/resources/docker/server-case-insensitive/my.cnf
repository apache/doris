# MySQL config with lower_case_table_names=1 so table names are stored in
# lowercase regardless of CREATE TABLE casing.  Must be combined with a
# cleared data directory so MySQL re-initializes with this setting.
[mysqld]
server-id=223367
log-bin=mysql-bin
binlog-format=ROW
binlog-row-image=FULL
lower_case_table_names=1
